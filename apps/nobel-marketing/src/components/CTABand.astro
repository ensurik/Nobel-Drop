---
import GoldButton from "./GoldButton.astro";

interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow = "Neste drop",
  title = "Du vil ikke se det komme. Du vil føle det.",
  body = "Push-varselet kommer fredag kl. 10. Begrenset antall, faste pickup-vinduer, ingen ventelister. Last ned, registrer deg, og vær klar.",
  primaryHref = "https://app.nobeldrop.no",
  primaryLabel = "Åpne app.nobeldrop.no",
  secondaryHref = "/konseptet",
  secondaryLabel = "Slik fungerer det",
} = Astro.props;
---

<section class="relative overflow-hidden py-32" data-fade>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(200,162,76,0.08)_0%,transparent_60%)]"
    aria-hidden="true"
  >
  </div>

  <div class="container-edge relative">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-sans text-[11px] font-medium uppercase tracking-ultra-wide text-gold-200/80">
        {eyebrow}
      </p>
      <h2 class="mt-6 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl lg:text-7xl">
        {title}
      </h2>
      <p class="mt-8 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
        {body}
      </p>

      <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <GoldButton href={primaryHref} variant="primary" size="lg">
          {primaryLabel}
        </GoldButton>
        <GoldButton href={secondaryHref} variant="ghost" size="lg" arrow={false}>
          {secondaryLabel}
        </GoldButton>
      </div>

      <p class="mt-10 font-sans text-xs uppercase tracking-ultra-wide text-bone-500">
        Vipps · Apple Pay · Klarna · 100 % forhåndsbetalt
      </p>
    </div>
  </div>

  <div
    class="pointer-events-none absolute bottom-0 left-1/2 h-px w-1/3 -translate-x-1/2 bg-gradient-to-r from-transparent via-gold-400/60 to-transparent"
    aria-hidden="true"
  >
  </div>
</section>
