---
import GoldButton from "./GoldButton.astro";

interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow = "Neste drop",
  title = "Vi varsler. Du henter.",
  body = "Vi sender deg push når et nytt drop går live. Last ned, slå på varsler, og vær blant de første.",
  primaryHref = "https://shop.nobeldrop.no",
  primaryLabel = "Bestill nå",
  secondaryHref = "/slik-fungerer-det",
  secondaryLabel = "Slik fungerer det",
} = Astro.props;
---

<section class="relative py-32" data-fade>
  <div class="container-edge relative">
    <div class="mx-auto max-w-3xl text-center">
      <p class="label-tiny">{eyebrow}</p>
      <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-6xl lg:text-7xl">
        {title}
      </h2>
      <p class="mx-auto mt-8 max-w-xl font-sans text-[17px] leading-relaxed text-espresso-700">
        {body}
      </p>

      <div class="mt-12 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
        <GoldButton href={primaryHref} variant="primary" size="lg">
          {primaryLabel}
        </GoldButton>
        <GoldButton href={secondaryHref} variant="ghost" size="lg" arrow={false}>
          {secondaryLabel}
        </GoldButton>
      </div>

      <p class="mt-10 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
        Vipps · Apple Pay · Klarna
      </p>
    </div>
  </div>
</section>
