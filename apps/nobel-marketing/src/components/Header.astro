---
const links = [
  { href: "/konseptet", label: "Konseptet" },
  { href: "/produkter", label: "Produkter" },
  { href: "/leveringsruter", label: "Ruter" },
  { href: "/historien", label: "Arven" },
  { href: "/faq", label: "FAQ" },
];
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-40 border-b border-ink-600/60 bg-ink-900/80 backdrop-blur-md">
  <div class="container-edge flex h-16 items-center justify-between sm:h-20">
    <a href="/" class="group flex items-center gap-3" aria-label="Nobel Drop forside">
      <span
        class="font-display text-2xl tracking-wide text-bone-100 transition group-hover:text-gold-200 sm:text-[26px]"
      >
        Nobel<span class="ml-2 inline-block text-gold-200">Drop</span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Hovednavigasjon">
      {
        links.map((l) => {
          const active = currentPath === l.href;
          return (
            <a
              href={l.href}
              class={`relative font-sans text-sm tracking-wide transition ${
                active ? "text-gold-200" : "text-bone-300 hover:text-bone-100"
              }`}
            >
              {l.label}
              {active && (
                <span class="absolute -bottom-2 left-0 right-0 mx-auto h-px w-4 bg-gold-200" />
              )}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://app.nobeldrop.no"
        class="group hidden items-center gap-2 border border-gold-400/60 px-4 py-2 font-sans text-xs uppercase tracking-ultra-wide text-gold-200 transition hover:border-gold-200 hover:bg-gold-400/10 hover:text-gold-100 sm:inline-flex"
      >
        Åpne app
        <svg
          class="h-3 w-3 transition group-hover:translate-x-0.5"
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M2 6h8M7 2l4 4-4 4" />
        </svg>
      </a>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-bone-100"
        aria-label="Meny"
        aria-expanded="false"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="4" y1="8" x2="20" y2="8" />
          <line x1="4" y1="16" x2="20" y2="16" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-ink-600/60 bg-ink-900 md:hidden"
  >
    <nav class="container-edge py-6">
      <div class="flex flex-col gap-5">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="font-display text-2xl text-bone-100 hover:text-gold-200"
            >
              {l.label}
            </a>
          ))
        }
        <a
          href="https://app.nobeldrop.no"
          class="mt-4 inline-flex items-center justify-between border border-gold-400/60 px-4 py-3 font-sans text-xs uppercase tracking-ultra-wide text-gold-200"
        >
          Åpne app
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
    });
  }
</script>
