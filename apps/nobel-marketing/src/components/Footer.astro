---
const year = new Date().getFullYear();
---

<footer class="relative mt-32 border-t border-espresso-900/10 bg-cream-100">
  <div class="container-edge grid gap-16 py-20 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <p class="label-tiny mb-4">Fra Nobel Catering & Conditori · Bærum siden 1986</p>
      <h3 class="font-display text-[40px] leading-[1.05] tracking-tight text-espresso-900 sm:text-5xl">
        Vi varsler.
        <br />
        <span class="display-italic text-brass-700">Du henter.</span>
      </h3>
      <p class="mt-6 max-w-md font-sans text-[15px] leading-relaxed text-espresso-600">
        Friskbakte makroner, kaker og dessertbokser fra et 39-årig konditori i Bærum.
        Bestilt i appen — hentet på stoppet ditt.
      </p>
      <a
        href="https://shop.nobeldrop.no"
        class="group mt-8 inline-flex items-center gap-3 rounded-full bg-espresso-900 px-6 py-3.5 font-sans text-sm font-medium text-cream-50 transition hover:bg-espresso-800"
      >
        Bestill nå
        <svg
          class="h-3.5 w-3.5 transition group-hover:translate-x-0.5"
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M2 6h8M7 2l4 4-4 4"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-2 gap-10 lg:col-span-7 lg:grid-cols-3">
      <div>
        <p class="label-tiny mb-5">Utforsk</p>
        <ul class="space-y-3 font-sans text-[14px] text-espresso-700">
          <li><a href="/slik-fungerer-det" class="hover:text-brass-700">Slik fungerer det</a></li>
          <li><a href="/produkter" class="hover:text-brass-700">Sortimentet</a></li>
          <li><a href="/hentesteder" class="hover:text-brass-700">Hentesteder</a></li>
          <li><a href="/om-nobel" class="hover:text-brass-700">Om Nobel</a></li>
        </ul>
      </div>

      <div>
        <p class="label-tiny mb-5">Bestill</p>
        <ul class="space-y-3 font-sans text-[14px] text-espresso-700">
          <li><a href="https://shop.nobeldrop.no" class="hover:text-brass-700">Åpne shop.nobeldrop.no</a></li>
          <li><a href="/faq" class="hover:text-brass-700">Vanlige spørsmål</a></li>
          <li><a href="/kontakt" class="hover:text-brass-700">Kontakt oss</a></li>
        </ul>
      </div>

      <div class="col-span-2 lg:col-span-1">
        <p class="label-tiny mb-5">Kjøkkenet</p>
        <address class="not-italic font-sans text-[14px] leading-relaxed text-espresso-600">
          Nobel Catering & Conditori<br />
          Eiksveien 110<br />
          1361 Østerås, Bærum
        </address>
        <p class="mt-4 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
          Bakt for hånd siden 1986
        </p>
      </div>
    </div>
  </div>

  <div class="border-t border-espresso-900/10">
    <div
      class="container-edge flex flex-col items-start justify-between gap-4 py-6 sm:flex-row sm:items-center"
    >
      <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
        © {year} Nobel Catering & Conditori
      </p>
      <div class="flex gap-6 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
        <a href="/personvern" class="hover:text-brass-700">Personvern</a>
        <a href="/vilkar" class="hover:text-brass-700">Vilkår</a>
        <a href="https://nobelcatering.no" class="hover:text-brass-700">nobelcatering.no</a>
      </div>
    </div>
  </div>
</footer>
