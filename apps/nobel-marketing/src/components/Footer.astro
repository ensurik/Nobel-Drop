---
const year = new Date().getFullYear();
---

<footer class="relative mt-32 overflow-hidden border-t border-ink-600/60 bg-ink-950">
  <div
    class="pointer-events-none absolute -top-px left-1/2 h-px w-1/2 -translate-x-1/2 bg-gradient-to-r from-transparent via-gold-400/60 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="container-edge relative grid gap-16 py-20 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <p class="label-tiny mb-4">En kanal av Nobel Catering & Conditori</p>
      <h3 class="font-display text-4xl leading-[1.1] text-bone-100 sm:text-5xl">
        Sikre din neste <span class="text-gold-200">Drop</span>.
      </h3>
      <p class="mt-6 max-w-md font-sans text-base leading-relaxed text-bone-300">
        Begrenset antall slippes hver fredag. 100 % forhåndsbetalt, faste pickup-vinduer,
        håndverk fra et 39 år gammelt konditori i Bærum.
      </p>
      <a
        href="https://app.nobeldrop.no"
        class="group mt-8 inline-flex items-center gap-3 border border-gold-400 bg-gold-400/5 px-6 py-3 font-sans text-sm uppercase tracking-ultra-wide text-gold-100 transition hover:border-gold-200 hover:bg-gold-400/15"
      >
        Åpne app.nobeldrop.no
        <svg
          class="h-3.5 w-3.5 transition group-hover:translate-x-0.5"
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M2 6h8M7 2l4 4-4 4"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-2 gap-10 lg:col-span-7 lg:grid-cols-3">
      <div>
        <p class="label-tiny mb-5">Plattform</p>
        <ul class="space-y-3 font-sans text-sm text-bone-300">
          <li><a href="/konseptet" class="hover:text-gold-200">Konseptet</a></li>
          <li><a href="/produkter" class="hover:text-gold-200">Produkter</a></li>
          <li><a href="/leveringsruter" class="hover:text-gold-200">Leveringsruter</a></li>
          <li><a href="/historien" class="hover:text-gold-200">Arven</a></li>
        </ul>
      </div>

      <div>
        <p class="label-tiny mb-5">Bestill</p>
        <ul class="space-y-3 font-sans text-sm text-bone-300">
          <li><a href="https://app.nobeldrop.no" class="hover:text-gold-200">Åpne app</a></li>
          <li><a href="/faq" class="hover:text-gold-200">Slik fungerer det</a></li>
          <li><a href="/kontakt" class="hover:text-gold-200">Kontakt</a></li>
        </ul>
      </div>

      <div class="col-span-2 lg:col-span-1">
        <p class="label-tiny mb-5">Nobel Catering & Conditori</p>
        <address class="not-italic font-sans text-sm leading-relaxed text-bone-400">
          Eiksveien 110<br />
          1361 Østerås<br />
          Bærum, Norge
        </address>
        <p class="mt-4 font-sans text-xs uppercase tracking-ultra-wide text-bone-500">
          Etablert 1986
        </p>
      </div>
    </div>
  </div>

  <div class="border-t border-ink-700/60">
    <div
      class="container-edge flex flex-col items-start justify-between gap-4 py-6 sm:flex-row sm:items-center"
    >
      <p class="font-sans text-xs uppercase tracking-ultra-wide text-bone-500">
        © {year} Nobel Catering & Conditori. Alle rettigheter forbeholdt.
      </p>
      <div class="flex gap-6 font-sans text-xs uppercase tracking-ultra-wide text-bone-500">
        <a href="/personvern" class="hover:text-gold-200">Personvern</a>
        <a href="/vilkar" class="hover:text-gold-200">Vilkår</a>
        <a href="https://nobelcatering.no" class="hover:text-gold-200">nobelcatering.no</a>
      </div>
    </div>
  </div>
</footer>
