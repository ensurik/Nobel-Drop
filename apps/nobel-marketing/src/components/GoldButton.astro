---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  external?: boolean;
  arrow?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  external = false,
  arrow = true,
  class: className = "",
} = Astro.props;

const baseClasses =
  "group inline-flex items-center justify-center gap-3 font-sans font-medium transition";

const sizeClasses =
  size === "lg" ? "px-7 py-4 text-[14px]" : "px-5 py-3 text-[13px]";

const variantClasses = {
  primary:
    "rounded-full bg-espresso-900 text-cream-50 hover:bg-espresso-800 shadow-[0_2px_0_rgba(15,10,6,0.04),0_8px_24px_-8px_rgba(26,20,16,0.35)]",
  secondary:
    "rounded-full bg-brass-500 text-cream-50 hover:bg-brass-600 shadow-[0_2px_0_rgba(15,10,6,0.04),0_8px_24px_-8px_rgba(163,125,46,0.45)]",
  ghost:
    "rounded-full border border-espresso-900/20 text-espresso-900 hover:border-espresso-900/45 hover:bg-cream-100",
}[variant];
---

<a
  href={href}
  class:list={[baseClasses, sizeClasses, variantClasses, className]}
  rel={external ? "noopener noreferrer" : undefined}
  target={external ? "_blank" : undefined}
>
  <slot />
  {
    arrow && (
      <svg
        class="h-3.5 w-3.5 transition group-hover:translate-x-0.5"
        viewBox="0 0 12 12"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M2 6h8M7 2l4 4-4 4" />
      </svg>
    )
  }
</a>
