---
interface Props {
  label: string;
  align?: "left" | "center";
}

const { label, align = "left" } = Astro.props;
---

<div
  class:list={[
    "flex items-center gap-3",
    align === "center" && "justify-center",
  ]}
>
  <span class="h-px w-6 bg-brass-500"></span>
  <span class="font-sans text-[11px] font-medium uppercase tracking-ultra-wide text-brass-700">
    {label}
  </span>
  <span class="h-px w-6 bg-brass-500"></span>
</div>
