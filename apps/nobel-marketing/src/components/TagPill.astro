---
interface Props {
  size?: "sm" | "md";
  class?: string;
}
const { size = "md", class: className = "" } = Astro.props;
const sizeClass =
  size === "sm" ? "px-3 py-1 text-[11px]" : "px-5 py-2 text-xs";
---

<span
  class:list={[
    "inline-flex items-center justify-center rounded-full border border-gold-400/55 bg-ink-900/40 font-sans uppercase tracking-ultra-wide text-gold-100",
    sizeClass,
    className,
  ]}
>
  <slot />
</span>
