---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  aspect?: string;
  class?: string;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
  fallbackLabel?: string;
}

const {
  src,
  alt,
  caption,
  aspect = "aspect-[4/3]",
  class: className = "",
  loading = "lazy",
  fetchpriority = "auto",
  fallbackLabel,
} = Astro.props;
---

<figure class:list={["group", className]}>
  <div class:list={["photo-frame img-fallback w-full overflow-hidden", aspect]}>
    <img
      src={src}
      alt={alt}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding="async"
      class="h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.02]"
      onerror="this.style.display='none'"
    />
    {
      fallbackLabel && (
        <div class="pointer-events-none absolute inset-0 flex items-end justify-start p-6">
          <span class="font-display text-sm italic text-espresso-600/40">
            {fallbackLabel}
          </span>
        </div>
      )
    }
  </div>
  {
    caption && (
      <figcaption class="mt-3 font-display text-sm italic text-espresso-600">
        {caption}
      </figcaption>
    )
  }
</figure>
