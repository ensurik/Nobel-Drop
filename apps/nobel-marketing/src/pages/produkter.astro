---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import HairlineFrame from "~/components/HairlineFrame.astro";
import TagPill from "~/components/TagPill.astro";
import CTABand from "~/components/CTABand.astro";

const products = [
  {
    slug: "macron",
    title: "Signaturmakronen",
    line: "Hovedboksen",
    headline: "Friskpiped fredag morgen",
    body: "Sprø skall, mykt indre, brent karamell på toppen. Vi piper hver makron for hånd samme morgen som dropet. Du smaker forskjellen — det er hele grunnen til at boksen er begrenset.",
    facts: [
      "4-pakk · 6-pakk · 8-pakk",
      "Brent karamell · mørk sjokolade · hasselnøtt · sesongens smak",
      "Holder seg fersk i 3 dager — om du klarer å vente",
    ],
    accent: "Hver fredag · ingen abonnement",
  },
  {
    slug: "porsjonskaker",
    title: "Porsjonskaker & Mini Cakes",
    line: "For de små fredene",
    headline: "Petit four, mini-cheesecake, mousse",
    body: "Små desserter for to til fire personer — perfekte til søndagskaffen, til dåpsfeiringen, eller bare som en stille kveld med noen du er glad i. Vi varierer utvalget gjennom året; sjekk hvilke som er klare i appen før du bestiller.",
    facts: [
      "2–4 porsjoner per stykk",
      "Sjokolademousse · sitronterte · bær på vanilje · pistasj-petit four",
      "Skiftende sortiment — sesongstyrt",
    ],
    accent: "Lett å legge til når du bestiller boks",
  },
  {
    slug: "premiumkake",
    title: "Premiumkaken",
    line: "Når det skal feires",
    headline: "Hele kaker for helgen",
    body: "Bursdag, dåp, helgebesøk, søndagsmiddag. Bestill fredag, hent samme dag, server lørdag eller søndag. Ekte mandelbunn, ekte krem, friske bær — den slags kake du husker fra barndommen, fortsatt bakt på samme måte.",
    facts: [
      "8 · 12 · 16 personer",
      "Sjokolade · bringebær · hasselnøtt · sesong",
      "Gluten- og laktosefri på utvalgte drops",
    ],
    accent: "Ferdig pakket · klar til å settes på bordet",
  },
  {
    slug: "middag",
    title: "Middag i porsjon",
    line: "Kommer Q4 2026",
    headline: "Hverdagsmiddag, premium-løftet",
    body: "Coq au vin, viltgryte, lakseretter — singel-pakket og klar for ovnen. Praktisk kraftkartong som tåler 200 grader, hevet til luksus med et mørkt mage-belte og gullfoliert logo. Samme app, samme stopp, samme håndverk.",
    facts: [
      "1–2 porsjoner per pakke",
      "Coq au vin · viltgryte · lakseretter · vegetar",
      "Klar i ovn på 25 minutter — eller mikro på 5",
    ],
    accent: "Lanseres når makron-rutinen sitter",
  },
];
---

<BaseLayout
  title="Bakverket"
  description="Signaturmakronen er hovedboksen. Porsjonskaker passer til søndagskaffen. Hele kaker til helgens feiring. Alt friskbakt fredag morgen, alt fra Nobels kjøkken."
>
  <!-- HERO -->
  <section class="relative overflow-hidden pt-24 pb-24 sm:pt-36 sm:pb-32">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(200,162,76,0.08)_0%,transparent_55%)]"
      aria-hidden="true"
    >
    </div>
    <div class="container-edge relative">
      <div class="mx-auto max-w-4xl text-center">
        <SectionLabel label="Bakverket" align="center" />
        <h1
          class="mt-8 font-display text-5xl leading-[1.02] text-bone-100 sm:text-7xl lg:text-[104px]"
          data-fade
        >
          Det vi baker<br />
          <span class="italic text-shimmer">til hver fredag</span>.
        </h1>
        <p class="mx-auto mt-10 max-w-2xl font-sans text-lg leading-relaxed text-bone-300" data-fade>
          Hovedboksen er signaturmakronen — det er det vi er kjent for. Du kan legge til
          porsjonskaker for to, eller en hel premiumkake til helgens besøk. Alt i samme
          bestilling, alt klart samme morgen.
        </p>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- PRODUKTER -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="space-y-32 sm:space-y-44">
        {
          products.map((p, i) => {
            const reverse = i % 2 === 1;
            return (
              <article class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-20">
                <div
                  class:list={[
                    "lg:col-span-7",
                    reverse ? "lg:order-2" : "lg:order-1",
                  ]}
                  data-fade
                >
                  <HairlineFrame class="aspect-[4/3] bg-gradient-to-br from-ink-850 via-ink-900 to-ink-800">
                    <div class="absolute inset-0 flex items-center justify-center p-10">
                      <div class="text-center">
                        <p class="font-sans text-[10px] uppercase tracking-ultra-wide text-gold-200/70">
                          Bakverk {String(i + 1).padStart(2, "0")} / 04
                        </p>
                        <p class="mt-6 font-display text-4xl text-gold-200 sm:text-6xl">
                          {p.title}
                        </p>
                        <div class="mx-auto mt-6 h-px w-16 bg-gold-400/40" />
                        <p class="mt-6 font-sans text-xs uppercase tracking-ultra-wide text-bone-500">
                          {p.accent}
                        </p>
                      </div>
                    </div>
                  </HairlineFrame>
                </div>

                <div
                  class:list={[
                    "lg:col-span-5",
                    reverse ? "lg:order-1" : "lg:order-2",
                  ]}
                  data-fade
                >
                  <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-gold-200/80">
                    {p.line}
                  </p>
                  <h2 class="mt-4 font-display text-4xl leading-[1.05] text-bone-100 sm:text-5xl">
                    {p.headline}
                  </h2>
                  <p class="mt-6 font-sans text-base leading-relaxed text-bone-300">
                    {p.body}
                  </p>

                  <ul class="mt-10 space-y-4 border-l border-gold-400/40 pl-6">
                    {p.facts.map((f) => (
                      <li class="font-sans text-sm leading-relaxed text-bone-200">
                        — {f}
                      </li>
                    ))}
                  </ul>

                  <div class="mt-10">
                    <GoldButton href="https://app.nobeldrop.no" variant="primary">
                      Se i appen
                    </GoldButton>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- BAKT FOR ANLEDNINGEN -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Når det smaker best" align="center" />
        <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-5xl">
          Bakt for fredagen.<br />Klar til lørdagen.
        </h2>
        <p class="mt-8 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
          De fleste bestiller før helgen — en boks til kvelden, en hel kake til søndagens
          besøk. Andre tar med en boks som vertinnegave, eller fyller en porsjonskake i
          fanget på fredagskvelden.
        </p>
      </div>

      <div class="mt-16 flex flex-wrap items-center justify-center gap-3 sm:gap-4" data-fade>
        <TagPill>Fredagskos</TagPill>
        <TagPill>Søndagskaffe</TagPill>
        <TagPill>Bursdagskake</TagPill>
        <TagPill>Helgebesøk</TagPill>
        <TagPill>Vertinnegave</TagPill>
        <TagPill>Dåp & feiring</TagPill>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- INGREDIENSER -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center lg:gap-24">
        <div data-fade>
          <SectionLabel label="Råvarene" />
          <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
            Smør, mandler,
            <br /><span class="italic text-gold-200">og tid.</span>
          </h2>
          <p class="mt-8 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
            Vi tar snarveiene aldri i kjøkkenet. Smør fra norske leverandører, mandler
            fra Spania, sjokolade fra produsenter vi har jobbet med i tjue år. Bær og
            frukt etter sesong — vi følger hva som er friskt, ikke hva som er
            tilgjengelig året rundt.
          </p>
          <p class="mt-6 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
            Vi har vært miljøfyrtårn-sertifisert lenge. Hele leveringsflåten er elektrisk.
            Drop-modellen betyr i tillegg at vi nesten ikke kaster noe — vi baker mot
            låste bestillinger, så ingenting står og blir gammelt på en disk.
          </p>
        </div>

        <div data-fade>
          <div class="grid grid-cols-2 gap-px bg-gold-400/15">
            <div class="bg-ink-900 p-8">
              <p class="font-display text-5xl text-gold-200">100%</p>
              <p class="mt-3 font-sans text-sm uppercase tracking-ultra-wide text-bone-400">
                Ekte smør
              </p>
              <p class="mt-2 font-sans text-xs leading-relaxed text-bone-500">
                Aldri margarin. Aldri palmeolje. Smaken kommer fra grunnlaget.
              </p>
            </div>
            <div class="bg-ink-900 p-8">
              <p class="font-display text-5xl text-gold-200">39 år</p>
              <p class="mt-3 font-sans text-sm uppercase tracking-ultra-wide text-bone-400">
                Med samme oppskrift
              </p>
              <p class="mt-2 font-sans text-xs leading-relaxed text-bone-500">
                Vi har endret menyen mange ganger, men aldri grunnoppskriftene.
              </p>
            </div>
            <div class="bg-ink-900 p-8">
              <p class="font-display text-5xl text-gold-200">≈ 0</p>
              <p class="mt-3 font-sans text-sm uppercase tracking-ultra-wide text-bone-400">
                Svinn
              </p>
              <p class="mt-2 font-sans text-xs leading-relaxed text-bone-500">
                Vi baker mot låste bestillinger — ingenting blir kastet på fredag kveld.
              </p>
            </div>
            <div class="bg-ink-900 p-8">
              <p class="font-display text-5xl text-gold-200">EL</p>
              <p class="mt-3 font-sans text-sm uppercase tracking-ultra-wide text-bone-400">
                Hele leveringsflåten
              </p>
              <p class="mt-2 font-sans text-xs leading-relaxed text-bone-500">
                Bilene som kjører til ditt hentested er elektriske. Miljøfyrtårn-sertifisert.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Klar?"
    title="Hver fredag kl. 10. Begrenset antall."
    body="Når dropet går live, har du minutter — ikke timer. Sett varselet, vær klar."
    primaryLabel="Last ned appen"
    secondaryHref="/hentesteder"
    secondaryLabel="Se hentestedene"
  />
</BaseLayout>
