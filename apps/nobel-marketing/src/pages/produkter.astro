---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import Photo from "~/components/Photo.astro";
import TagPill from "~/components/TagPill.astro";
import CTABand from "~/components/CTABand.astro";

const products = [
  {
    title: "Signaturmakronen",
    line: "Hovedboksen",
    headline: "Sprø skall, mykt indre",
    body: "Vi piper hver makron for hånd samme morgen som dropet. Brent karamell på toppen, et hint av sjøsalt, mørk sjokolade som smelter sakte. Du smaker forskjellen — det er hele grunnen til at boksen er begrenset.",
    facts: [
      "4-pakk · 6-pakk · 8-pakk",
      "Brent karamell · mørk sjokolade · hasselnøtt · sesongens smak",
      "Fersk i 3 dager — om du klarer å vente",
    ],
    accent: "Hver gang vi baker · ingen abonnement",
    image: "/assets/products/macron.jpg",
    fallback: "Bilde · Signaturmakronen",
  },
  {
    title: "Porsjonskaker & Mini Cakes",
    line: "For to og fire",
    headline: "Petit four, mousse, terter",
    body: "Små desserter for to til fire personer — perfekte til søndagskaffen, til dåpsfeiringen, eller bare som en stille kveld med noen du er glad i. Vi varierer utvalget gjennom året; sjekk i appen før du bestiller.",
    facts: [
      "2–4 porsjoner per stykk",
      "Sjokolademousse · sitronterte · bær på vanilje · pistasj-petit four",
      "Skiftende sortiment — sesongstyrt",
    ],
    accent: "Lett å legge til når du bestiller",
    image: "/assets/products/porsjonskaker.jpg",
    fallback: "Bilde · Porsjonskaker",
  },
  {
    title: "Premiumkaken",
    line: "Hele kaker",
    headline: "Kaken til helgen",
    body: "Bursdag, dåp, helgebesøk, søndagsmiddag. Bestill, hent, server — den slags kake du husker fra barndommen, fortsatt bakt på samme måte. Mandelbunn, friske bær, ekte krem.",
    facts: [
      "8 · 12 · 16 personer",
      "Sjokolade · bringebær · hasselnøtt · sesong",
      "Gluten- og laktosefri på utvalgte drops",
    ],
    accent: "Klar til å settes på bordet",
    image: "/assets/products/premiumkake.jpg",
    fallback: "Bilde · Premiumkaken",
  },
  {
    title: "Middag i porsjon",
    line: "Kommer Q4 2026",
    headline: "Hverdagsmiddag, premium-løftet",
    body: "Coq au vin, viltgryte, lakseretter — singel-pakket og klar for ovnen. Praktisk kraftkartong som tåler 200 grader, hevet til luksus med et mørkt mage-belte og gullfoliert logo. Samme app, samme stopp, samme håndverk.",
    facts: [
      "1–2 porsjoner per pakke",
      "Coq au vin · viltgryte · lakseretter · vegetar",
      "Klar i ovn på 25 minutter",
    ],
    accent: "Lanseres når makron-rutinen sitter",
    image: "/assets/products/middag.jpg",
    fallback: "Bilde · Middag i porsjon",
  },
];
---

<BaseLayout
  title="Bakverket"
  description="Signaturmakronen er hovedboksen. Porsjonskaker passer til søndagskaffen. Hele kaker til helgens feiring. Alt friskbakt, alt fra Nobels kjøkken."
>
  <!-- HERO -->
  <section class="relative pt-12 pb-20 sm:pt-20 sm:pb-28">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end lg:gap-16">
        <div class="lg:col-span-7 lg:pb-8">
          <SectionLabel label="Bakverket" />
          <h1
            class="mt-8 font-display text-[52px] font-medium leading-[0.98] tracking-tight text-espresso-900 sm:text-7xl lg:text-[88px]"
            data-fade
          >
            Det vi
            <br />
            <span class="display-italic text-brass-700">faktisk baker</span>.
          </h1>
          <p
            class="mt-10 max-w-xl font-sans text-[17px] leading-relaxed text-espresso-700 sm:text-[18px]"
            data-fade
          >
            Hovedboksen er signaturmakronen — det er det vi er kjent for. Du kan
            legge til porsjonskaker for to, eller en hel premiumkake til helgens
            besøk. Alt i samme bestilling, alt klart samme dag.
          </p>
        </div>

        <div class="lg:col-span-5" data-fade>
          <Photo
            src="/assets/products/macron.jpg"
            alt="Stabel av Nobel-makroner i fire smaker"
            aspect="aspect-[4/5]"
            loading="eager"
            fetchpriority="high"
            fallbackLabel="Bilde · Stabel av makroner"
          />
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- PRODUKTER -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="space-y-32 sm:space-y-44">
        {
          products.map((p, i) => {
            const reverse = i % 2 === 1;
            return (
              <article class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-20">
                <div
                  class:list={[
                    "lg:col-span-7",
                    reverse ? "lg:order-2" : "lg:order-1",
                  ]}
                  data-fade
                >
                  <Photo
                    src={p.image}
                    alt={p.title}
                    aspect="aspect-[4/3]"
                    fallbackLabel={p.fallback}
                  />
                </div>

                <div
                  class:list={[
                    "lg:col-span-5",
                    reverse ? "lg:order-1" : "lg:order-2",
                  ]}
                  data-fade
                >
                  <p class="font-sans text-[10px] uppercase tracking-ultra-wide text-brass-700">
                    {p.line}
                  </p>
                  <h2 class="mt-3 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-[52px]">
                    {p.headline}
                  </h2>
                  <p class="mt-6 font-sans text-[16px] leading-relaxed text-espresso-700 sm:text-[17px]">
                    {p.body}
                  </p>

                  <ul class="mt-10 space-y-3 border-l border-brass-300 pl-6">
                    {p.facts.map((f) => (
                      <li class="font-sans text-[14px] leading-relaxed text-espresso-700">
                        — {f}
                      </li>
                    ))}
                  </ul>

                  <p class="mt-8 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                    {p.accent}
                  </p>

                  <div class="mt-8">
                    <GoldButton href="https://shop.nobeldrop.no" variant="primary">
                      Se i appen
                    </GoldButton>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- ANLEDNINGER -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Når det smaker best" align="center" />
        <h2 class="mt-8 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-5xl">
          Bakt for hverdagen.
          <br />
          <span class="display-italic text-brass-700">Klar for feiringen.</span>
        </h2>
        <p class="mt-8 font-sans text-[16px] leading-relaxed text-espresso-700 sm:text-[17px]">
          De fleste bestiller før helgen — en boks til kvelden, en hel kake til
          søndagens besøk. Andre tar med en boks som vertinnegave, eller fyller
          en porsjonskake i fanget på fredagskvelden.
        </p>
      </div>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-2.5" data-fade>
        <TagPill>Søndagskaffe</TagPill>
        <TagPill>Bursdagskake</TagPill>
        <TagPill>Helgebesøk</TagPill>
        <TagPill>Vertinnegave</TagPill>
        <TagPill>Dåp og feiring</TagPill>
        <TagPill>Etter en lang uke</TagPill>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- INGREDIENSER -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-20">
        <div class="lg:col-span-6" data-fade>
          <SectionLabel label="Råvarene" />
          <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-[60px]">
            Smør, mandler,
            <br />
            <span class="display-italic text-brass-700">og tid.</span>
          </h2>
          <p class="mt-8 font-sans text-[16px] leading-[1.7] text-espresso-700 sm:text-[17px]">
            Vi tar snarveiene aldri i kjøkkenet. Smør fra norske leverandører,
            mandler fra Spania, sjokolade fra produsenter vi har jobbet med i
            tjue år. Bær og frukt etter sesong — vi følger hva som er friskt,
            ikke hva som er tilgjengelig året rundt.
          </p>
          <p class="mt-5 font-sans text-[16px] leading-[1.7] text-espresso-700 sm:text-[17px]">
            Vi har vært miljøfyrtårn-sertifisert lenge. Hele leveringsflåten er
            elektrisk. Drop-modellen betyr i tillegg at vi nesten ikke kaster
            noe — vi baker mot låste bestillinger.
          </p>
        </div>

        <div class="lg:col-span-6" data-fade>
          <div class="grid grid-cols-2 gap-px bg-espresso-900/10">
            <div class="bg-cream-50 p-8">
              <p class="font-display text-[44px] font-medium leading-none text-brass-700">
                100 %
              </p>
              <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                Ekte smør
              </p>
              <p class="mt-2 font-sans text-[12px] leading-relaxed text-espresso-600">
                Aldri margarin. Aldri palmeolje. Smaken kommer fra grunnlaget.
              </p>
            </div>
            <div class="bg-cream-50 p-8">
              <p class="font-display text-[44px] font-medium leading-none text-brass-700">
                39 år
              </p>
              <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                Med samme oppskrift
              </p>
              <p class="mt-2 font-sans text-[12px] leading-relaxed text-espresso-600">
                Vi har endret menyen mange ganger, men aldri grunnoppskriftene.
              </p>
            </div>
            <div class="bg-cream-50 p-8">
              <p class="font-display text-[44px] font-medium leading-none text-brass-700">
                ≈ 0
              </p>
              <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                Svinn
              </p>
              <p class="mt-2 font-sans text-[12px] leading-relaxed text-espresso-600">
                Vi baker mot låste bestillinger — ingenting blir kastet.
              </p>
            </div>
            <div class="bg-cream-50 p-8">
              <p class="font-display text-[44px] font-medium leading-none text-brass-700">
                EL
              </p>
              <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                Hele leveringsflåten
              </p>
              <p class="mt-2 font-sans text-[12px] leading-relaxed text-espresso-600">
                Bilene som kjører til ditt stopp er elektriske.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Klar?"
    title="Begrenset antall. Bakt med tid."
    body="Vi varsler deg når neste drop er klart. Sett varselet, vær klar."
    primaryLabel="Bestill nå"
    secondaryHref="/hentesteder"
    secondaryLabel="Se hentestedene"
  />
</BaseLayout>
