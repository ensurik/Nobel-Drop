---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import HairlineFrame from "~/components/HairlineFrame.astro";
import CTABand from "~/components/CTABand.astro";

const flow = [
  {
    num: "1",
    title: "Last ned appen",
    body: "Søk opp Nobel Drop i App Store eller Google Play, eller åpne den direkte på app.nobeldrop.no. Lag konto med e-post — det tar under et minutt.",
    detail: "Slå på push-varsler så du blir varslet i samme sekund neste drop går live.",
  },
  {
    num: "2",
    title: "Få varsel fredag kl. 10",
    body: "Hver fredag morgen sender vi deg en push når dropet er åpent. Du ser med en gang hvor mange bokser som er igjen, og hvilke smaker som er tilgjengelige denne uken.",
    detail: "Inne i appen kan du også se hentestedene før dropet starter, slik at du er klar.",
  },
  {
    num: "3",
    title: "Velg boks og kake",
    body: "Plukk størrelse på boksen — 4, 6 eller 8 makroner. Legg til en porsjonskake for to, eller en hel premiumkake til søndagens besøk. Alt i samme kurv.",
    detail: "Du har 20 sekunder på å fullføre etter du har lagt i kurven. Vi reserverer plassen så lenge.",
  },
  {
    num: "4",
    title: "Betal med Vipps eller Apple Pay",
    body: "Ett trykk og du er ferdig. Vi støtter Vipps, Apple Pay og Klarna. Pengene reserveres med en gang slik at vi kan begynne å bake — du blir ikke trukket før vi har bakt boksen din.",
    detail: "Bestiller du for over 1 000 kr, får du Nobel-kreditt til neste fredag (mer om det lenger ned).",
  },
  {
    num: "5",
    title: "Velg hentested og tid",
    body: "Velg ditt nærmeste stopp — Lier, Drammen, Holmestrand, Horten eller Tønsberg. Vi har 30-minutters vinduer du kan booke deg inn i, maks 10 kunder per vindu, så ingen kø.",
    detail: "Du får øyeblikkelig en QR-kode i appen. Den er også på e-posten din.",
  },
  {
    num: "6",
    title: "Hent på 3 minutter",
    body: "Kjør til stoppet ditt i ditt valgte vindu. Vis QR-koden — vi har boksen din klar med navnet ditt på. Hele utleveringen tar tre minutter.",
    detail: "Boksen er pakket i kraftkartong med gullfoliert logo — perfekt om du skal videre med den som vertinnegave.",
  },
];

const credit = [
  { tier: "1 000 kr+", credit: "10 %", body: "En boks og litt til, eller en hel kake." },
  { tier: "1 500 kr+", credit: "15 %", body: "Boksen, kaken og porsjonskaker for besøket." },
  { tier: "2 000 kr+", credit: "20 %", body: "Helgens samlede dessert. Tjent kreditt til neste fredag." },
];
---

<BaseLayout
  title="Slik fungerer det"
  description="Last ned, få varsel fredag kl. 10, bestill på 30 sekunder, hent på ditt nærmeste stopp. Slik fungerer Nobel Drop steg for steg."
>
  <!-- HERO -->
  <section class="relative overflow-hidden pt-24 pb-24 sm:pt-36 sm:pb-32">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(200,162,76,0.08)_0%,transparent_55%)]"
      aria-hidden="true"
    >
    </div>
    <div class="container-edge relative">
      <div class="mx-auto max-w-4xl text-center">
        <SectionLabel label="Slik fungerer det" align="center" />
        <h1
          class="mt-8 font-display text-5xl leading-[1.02] text-bone-100 sm:text-7xl lg:text-[104px]"
          data-fade
        >
          Fra varsel til boks<br /><span class="italic text-shimmer">på én fredag</span>.
        </h1>
        <p class="mx-auto mt-10 max-w-2xl font-sans text-lg leading-relaxed text-bone-300" data-fade>
          Vi har bygget bestillingen så enkel at den passer inn mellom kaffepausen og
          neste møte. Last ned, slå på varsler, og du er ferdig på 30 sekunder når neste
          drop går live.
        </p>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- 6 STEG -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl" data-fade>
        <SectionLabel label="Hele flyten" />
        <h2 class="mt-6 font-display text-4xl leading-[1.05] text-bone-100 sm:text-5xl">
          Seks steg, ingen overraskelser.
        </h2>
      </div>

      <div class="mt-20 space-y-px bg-gold-400/15">
        {
          flow.map((s) => (
            <div class="grid bg-ink-900 lg:grid-cols-12 lg:items-start" data-fade>
              <div class="border-b border-ink-700/60 p-10 lg:col-span-2 lg:border-b-0 lg:border-r">
                <p class="font-display text-7xl leading-none text-gold-200">{s.num}</p>
                <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-bone-500">
                  Steg {s.num}
                </p>
              </div>
              <div class="p-10 lg:col-span-7">
                <h3 class="font-display text-3xl leading-tight text-bone-100">{s.title}</h3>
                <p class="mt-4 font-sans text-base leading-relaxed text-bone-300">
                  {s.body}
                </p>
              </div>
              <div class="border-l border-ink-700/60 p-10 lg:col-span-3">
                <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-gold-200/80">
                  Bra å vite
                </p>
                <p class="mt-3 font-sans text-sm leading-relaxed text-bone-400">
                  {s.detail}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- HVORFOR FORHÅNDSBETALING -->
  <section class="relative overflow-hidden py-32 sm:py-44">
    <div class="container-edge relative">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center lg:gap-24">
        <div data-fade>
          <SectionLabel label="Forhåndsbetaling" />
          <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
            Du betaler først
            <br />
            <span class="italic text-gold-200">— vi baker etterpå</span>.
          </h2>
          <p class="mt-8 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
            Vi krever forhåndsbetaling fordi vi baker hver eneste boks etter at bestillingen
            er låst. Det betyr at det aldri blir kastet noe — alt vi baker fredag morgen,
            er allerede solgt og venter på å bli hentet samme dag.
          </p>
          <p class="mt-6 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
            For deg betyr det at det du henter, er bakt samme morgen. For oss betyr det at
            vi kan jobbe med ekstra omhu. Ingen stress, ingen "kanskje noen kommer innom".
          </p>
        </div>

        <div data-fade>
          <HairlineFrame class="aspect-[4/5] bg-gradient-to-br from-ink-850 via-ink-900 to-ink-850">
            <div class="absolute inset-0 flex flex-col items-center justify-center p-10">
              <p class="font-sans text-[10px] uppercase tracking-ultra-wide text-gold-200/80">
                Du har
              </p>
              <p class="mt-3 font-display text-7xl tabular-nums text-bone-100 sm:text-8xl">
                <span class="text-shimmer">00:20</span>
              </p>
              <div class="mt-8 h-px w-24 bg-gold-400/60"></div>
              <p class="mt-8 max-w-xs text-center font-sans text-sm leading-relaxed text-bone-400">
                Reservasjonen holdes i 20 sekunder etter du har lagt i kurven. Det er nok
                tid til å trykke Vipps. Hvis du er for treg, frigjøres plassen til neste
                kunde — og du kan prøve igjen.
              </p>
            </div>
          </HairlineFrame>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- HENTING -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Henting" align="center" />
        <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
          Tre minutter
          <br /><span class="italic text-gold-200">— ut og inn</span>.
        </h2>
      </div>

      <div class="mx-auto mt-20 max-w-5xl">
        <div class="grid gap-px bg-gold-400/15 md:grid-cols-3" data-fade>
          <div class="bg-ink-900 p-10 text-center">
            <p class="font-display text-7xl text-gold-200 tabular-nums">90</p>
            <p class="mt-3 font-sans text-xs uppercase tracking-ultra-wide text-bone-400">
              Minutter på stoppet
            </p>
            <p class="mt-3 font-sans text-sm leading-relaxed text-bone-500">
              Vi står på hvert hentested i 90 minutter, slik at du finner et vindu som passer.
            </p>
          </div>
          <div class="bg-ink-900 p-10 text-center">
            <p class="font-display text-7xl text-gold-200 tabular-nums">30</p>
            <p class="mt-3 font-sans text-xs uppercase tracking-ultra-wide text-bone-400">
              Minutters vinduer
            </p>
            <p class="mt-3 font-sans text-sm leading-relaxed text-bone-500">
              Du booker deg inn i et 30-minutters vindu. Komme når du vil i det vinduet.
            </p>
          </div>
          <div class="bg-ink-900 p-10 text-center">
            <p class="font-display text-7xl text-gold-200 tabular-nums">10</p>
            <p class="mt-3 font-sans text-xs uppercase tracking-ultra-wide text-bone-400">
              Maks per vindu
            </p>
            <p class="mt-3 font-sans text-sm leading-relaxed text-bone-500">
              Vi setter et tak slik at det aldri står kø. Tre minutter per kunde, ingen stress.
            </p>
          </div>
        </div>

        <div class="mt-10 border border-gold-400/40 bg-ink-850 p-8 text-center" data-fade>
          <p class="font-display text-2xl italic text-gold-200">
            Vis QR. Få boksen. Kjør hjem.
          </p>
          <p class="mt-3 font-sans text-sm text-bone-400">
            Du trenger ikke å si navnet ditt. Vi kjenner deg igjen på koden.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- HVIS VI IKKE NÅR DITT STOPP -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center lg:gap-24">
        <div data-fade>
          <SectionLabel label="Hvis stoppet ikke aktiveres" />
          <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
            Vi kjører kun
            <br /><span class="italic text-gold-200">der det er etterspørsel</span>.
          </h2>
          <p class="mt-8 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
            Et hentested aktiveres bare hvis nok bestillinger ligger inne på det stoppet
            — typisk innen 12 timer før vi setter oss i bilen. Det er sånn vi sikrer at
            det er ferskt det vi leverer, og at vi ikke bruker tiden på en bil halvveis tom.
          </p>
          <p class="mt-6 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
            Hvis ditt stopp ikke aktiveres, får du to valg i appen: full refusjon med en gang,
            eller flytt bestillingen til et annet aktivt stopp uten ekstra kostnad. Vi sender
            deg push så snart vi vet.
          </p>
        </div>

        <div class="space-y-4" data-fade>
          <div class="border border-moss/40 bg-moss/5 p-6">
            <div class="flex items-center justify-between">
              <p class="font-display text-xl text-bone-100">Holmestrand</p>
              <span class="font-sans text-xs uppercase tracking-ultra-wide text-moss">
                Aktivert
              </span>
            </div>
            <div class="mt-4 h-1 w-full overflow-hidden bg-ink-700">
              <div class="h-full w-full bg-moss"></div>
            </div>
            <p class="mt-2 font-sans text-xs text-bone-500">Bilen kjører som planlagt</p>
          </div>

          <div class="border border-ember/40 bg-ember/5 p-6">
            <div class="flex items-center justify-between">
              <p class="font-display text-xl text-bone-100">Eksempelstopp</p>
              <span class="font-sans text-xs uppercase tracking-ultra-wide text-ember">
                Ikke nok bestillinger
              </span>
            </div>
            <div class="mt-4 h-1 w-full overflow-hidden bg-ink-700">
              <div class="h-full w-[40%] bg-ember"></div>
            </div>
            <p class="mt-2 font-sans text-xs text-bone-500">Du får valget om refusjon eller å bytte stopp</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- NOBEL-KREDITT -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Nobel-kreditt" align="center" />
        <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
          En takk fra oss
          <br /><span class="italic text-gold-200">når du bestiller stort</span>.
        </h2>
        <p class="mt-8 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
          Bestiller du for et helgebesøk eller en feiring, gir vi tilbake en del av kjøpet
          som Nobel-kreditt til neste fredag. Det er ikke en kupong eller rabatt — det er
          en skjult bonus som dukker opp i appen din etter henting.
        </p>
      </div>

      <div class="mx-auto mt-20 max-w-3xl space-y-3" data-fade>
        {
          credit.map((c, i) => (
            <div class="flex items-center gap-6 border border-gold-400/30 bg-ink-850 p-6 transition hover:border-gold-400/60">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center border border-gold-400/40 bg-ink-900 font-display text-xl text-gold-200">
                {i + 1}
              </div>
              <div class="flex-1">
                <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-gold-200/80">
                  Bestilling fra {c.tier}
                </p>
                <p class="mt-1 font-display text-xl text-bone-100">
                  Du får {c.credit} i Nobel-kreditt
                </p>
                <p class="mt-1 font-sans text-sm text-bone-400">{c.body}</p>
              </div>
              <div class="hidden font-display text-5xl text-gold-200 sm:block">
                {c.credit}
              </div>
            </div>
          ))
        }
      </div>

      <p class="mx-auto mt-12 max-w-2xl text-center font-sans text-sm leading-relaxed text-bone-400" data-fade>
        Krediten brukes som betalingsmiddel ved neste kjøp i appen, og er gyldig i 90
        dager. Ingen koder, ingen "husk å bruk denne på neste handel" — den ligger der og
        venter når du logger inn.
      </p>
    </div>
  </section>

  <CTABand
    eyebrow="Klar for fredag?"
    title="Last ned. Slå på varsler. Vi tar resten."
    body="Det tar et minutt å bli klar. Neste drop går live fredag kl. 10."
    primaryLabel="Last ned appen"
    secondaryHref="/produkter"
    secondaryLabel="Se hva vi baker"
  />
</BaseLayout>
