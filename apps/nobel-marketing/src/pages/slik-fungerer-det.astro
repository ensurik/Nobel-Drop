---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import Photo from "~/components/Photo.astro";
import CTABand from "~/components/CTABand.astro";

const flow = [
  {
    num: "01",
    title: "Last ned appen",
    body: "Søk opp Nobel Drop i App Store eller Google Play, eller åpne den på shop.nobeldrop.no. Konto med e-post — under et minutt.",
    detail: "Slå på push-varsler så du blir varslet i samme sekund neste drop går live.",
  },
  {
    num: "02",
    title: "Få varsel når et drop er live",
    body: "Vi varsler i appen når et nytt drop er klart. Du ser med en gang hva vi har bakt, hvilke smaker som er tilgjengelige, og hvor mange bokser som er igjen.",
    detail: "Drops kan komme én eller flere ganger i uken — alt etter hva som lages på kjøkkenet.",
  },
  {
    num: "03",
    title: "Velg boks og kake",
    body: "Plukk boks — 4, 6 eller 8 makroner. Legg til en porsjonskake for to, eller en hel premiumkake til helgens besøk. Alt i samme kurv.",
    detail: "Du har 20 sekunder på å fullføre etter du har lagt i kurven. Vi reserverer plassen så lenge.",
  },
  {
    num: "04",
    title: "Betal med Vipps eller Apple Pay",
    body: "Ett trykk og du er ferdig. Vi støtter Vipps, Apple Pay og Klarna. Pengene reserveres med en gang — du blir ikke trukket før vi har bakt boksen din.",
    detail: "Bestiller du for over 1 000 kr, får du Nobel-kreditt til neste gang. Mer om det lenger ned.",
  },
  {
    num: "05",
    title: "Velg hentested og tid",
    body: "Velg ditt nærmeste stopp — Lier, Drammen, Holmestrand, Horten eller Tønsberg. 30-minutters vinduer å booke deg inn i, maks 10 kunder per vindu, så ingen kø.",
    detail: "Du får øyeblikkelig en QR-kode i appen. Den ligger også i e-posten din.",
  },
  {
    num: "06",
    title: "Hent på 3 minutter",
    body: "Kjør til stoppet ditt i ditt valgte vindu. Vis QR-koden — vi har boksen klar med navnet ditt på. Ut og inn på tre minutter.",
    detail: "Boksen er pakket i kraftkartong med gullfoliert logo — perfekt om du tar den med som vertinnegave.",
  },
];

const credit = [
  { tier: "1 000 kr+", credit: "10 %", body: "En boks og litt til, eller en hel kake." },
  { tier: "1 500 kr+", credit: "15 %", body: "Boksen, kaken og porsjonskaker for besøket." },
  { tier: "2 000 kr+", credit: "20 %", body: "Helgens samlede dessert. Tjent kreditt til neste gang." },
];
---

<BaseLayout
  title="Slik fungerer det"
  description="Last ned, få varsel når et nytt drop er live, bestill på 30 sekunder, hent på ditt nærmeste stopp. Slik fungerer Nobel Drop steg for steg."
>
  <!-- HERO -->
  <section class="relative pt-12 pb-20 sm:pt-20 sm:pb-28">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end lg:gap-16">
        <div class="lg:col-span-7 lg:pb-8">
          <SectionLabel label="Slik fungerer det" />
          <h1
            class="mt-8 font-display text-[52px] font-medium leading-[0.98] tracking-tight text-espresso-900 sm:text-7xl lg:text-[88px]"
            data-fade
          >
            Bestilt med ett trykk.
            <br />
            <span class="display-italic text-brass-700">Hentet samme dag.</span>
          </h1>
          <p
            class="mt-10 max-w-xl font-sans text-[17px] leading-relaxed text-espresso-700 sm:text-[18px]"
            data-fade
          >
            Vi har bygget bestillingen så enkel at den passer mellom kaffepausen og
            neste møte. Last ned, slå på varsler, og du er ferdig på 30 sekunder
            når neste drop går live.
          </p>
        </div>

        <div class="lg:col-span-5" data-fade>
          <Photo
            src="/assets/hero/macron-detail.jpg"
            alt="Detalj av en Nobel-makron med gullflak"
            aspect="aspect-[4/5]"
            loading="eager"
            fetchpriority="high"
            fallbackLabel="Detalj · Makron med gullflak"
          />
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- 6 STEG -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto mb-16 max-w-3xl" data-fade>
        <SectionLabel label="Hele flyten" />
        <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-5xl">
          Seks steg.
          <span class="display-italic text-brass-700">Ingen overraskelser.</span>
        </h2>
      </div>

      <ol class="mx-auto max-w-5xl divide-y divide-espresso-900/10 border-y border-espresso-900/10">
        {
          flow.map((s) => (
            <li class="grid grid-cols-12 gap-6 px-1 py-12" data-fade>
              <div class="col-span-12 sm:col-span-2">
                <span class="font-display text-[44px] font-medium leading-none text-brass-600 sm:text-[64px]">
                  {s.num}
                </span>
              </div>
              <div class="col-span-12 sm:col-span-7">
                <h3 class="font-display text-[26px] font-medium leading-tight text-espresso-900 sm:text-[34px]">
                  {s.title}
                </h3>
                <p class="mt-3 font-sans text-[15px] leading-relaxed text-espresso-700 sm:text-[16px]">
                  {s.body}
                </p>
              </div>
              <div class="col-span-12 sm:col-span-3">
                <p class="font-sans text-[10px] uppercase tracking-ultra-wide text-brass-700">
                  Bra å vite
                </p>
                <p class="mt-2 font-sans text-[13px] leading-relaxed text-espresso-600">
                  {s.detail}
                </p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- HVORFOR FORHÅNDSBETALING -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-20">
        <div class="lg:col-span-6" data-fade>
          <SectionLabel label="Forhåndsbetaling" />
          <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-[60px]">
            Du betaler først.
            <br />
            <span class="display-italic text-brass-700">Vi baker etterpå.</span>
          </h2>
          <p class="mt-8 font-sans text-[16px] leading-[1.7] text-espresso-700 sm:text-[17px]">
            Vi krever forhåndsbetaling fordi vi baker hver eneste boks etter at
            bestillingen er låst. Det betyr at det aldri blir kastet noe — alt vi
            baker, er allerede solgt og venter på å bli hentet.
          </p>
          <p class="mt-5 font-sans text-[16px] leading-[1.7] text-espresso-700 sm:text-[17px]">
            For deg betyr det at det du henter er bakt samme dag. For oss betyr
            det at vi kan jobbe med ekstra omhu. Ingen stress, ingen "kanskje
            noen kommer innom".
          </p>
        </div>

        <div class="lg:col-span-6" data-fade>
          <Photo
            src="/assets/about/oven.jpg"
            alt="Et øyeblikk fra Nobel-kjøkkenet — varmt lys, hender ved ovn"
            aspect="aspect-[4/5]"
            fallbackLabel="Bilde · Et øyeblikk fra kjøkkenet"
          />
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- HENTING -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Henting" align="center" />
        <h2 class="mt-8 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-6xl">
          Tre minutter,
          <span class="display-italic text-brass-700">ut og inn</span>.
        </h2>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-3 gap-px bg-espresso-900/10 text-center" data-fade>
        <div class="bg-cream-50 px-4 py-10 sm:py-14">
          <p class="font-display text-[56px] font-medium leading-none text-brass-700 sm:text-[88px]">
            90
          </p>
          <p class="mt-4 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
            Min på stoppet
          </p>
          <p class="mx-auto mt-3 max-w-[180px] font-sans text-[12px] leading-relaxed text-espresso-600 sm:text-[13px]">
            Vi står på hvert hentested i 90 minutter slik at du finner et vindu som passer.
          </p>
        </div>
        <div class="bg-cream-50 px-4 py-10 sm:py-14">
          <p class="font-display text-[56px] font-medium leading-none text-brass-700 sm:text-[88px]">
            30
          </p>
          <p class="mt-4 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
            Min vinduer
          </p>
          <p class="mx-auto mt-3 max-w-[180px] font-sans text-[12px] leading-relaxed text-espresso-600 sm:text-[13px]">
            Du booker det vinduet som passer deg. Komme når du vil i det vinduet.
          </p>
        </div>
        <div class="bg-cream-50 px-4 py-10 sm:py-14">
          <p class="font-display text-[56px] font-medium leading-none text-brass-700 sm:text-[88px]">
            10
          </p>
          <p class="mt-4 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
            Maks per vindu
          </p>
          <p class="mx-auto mt-3 max-w-[180px] font-sans text-[12px] leading-relaxed text-espresso-600 sm:text-[13px]">
            Vi setter et tak slik at det aldri står kø. Tre minutter per kunde.
          </p>
        </div>
      </div>

      <p class="mx-auto mt-12 max-w-2xl text-center font-display text-[22px] italic text-brass-700 sm:text-[28px]" data-fade>
        Vis QR. Få boksen. Kjør hjem.
      </p>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- VOLUMSTYRT -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-20">
        <div class="lg:col-span-6" data-fade>
          <SectionLabel label="Hvis stoppet ikke aktiveres" />
          <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-[52px]">
            Vi kjører kun
            <br />
            <span class="display-italic text-brass-700">der det er etterspørsel</span>.
          </h2>
          <p class="mt-8 font-sans text-[16px] leading-[1.7] text-espresso-700">
            Et hentested aktiveres bare hvis nok bestillinger ligger inne på det
            stoppet — typisk innen 12 timer før vi setter oss i bilen. Det er sånn
            vi sikrer at det er ferskt det vi leverer, og at vi ikke bruker tiden
            på en bil halvveis tom.
          </p>
          <p class="mt-5 font-sans text-[16px] leading-[1.7] text-espresso-700">
            Hvis ditt stopp ikke aktiveres, får du to valg i appen: full refusjon
            med en gang, eller flytt bestillingen til et annet aktivt stopp uten
            ekstra kostnad. Vi sender deg push så snart vi vet.
          </p>
        </div>

        <div class="space-y-3 lg:col-span-6" data-fade>
          <div class="rounded-lg border border-moss/30 bg-moss/5 p-6">
            <div class="flex items-center justify-between">
              <p class="font-display text-[20px] font-medium text-espresso-900">
                Holmestrand
              </p>
              <span class="font-sans text-[10px] uppercase tracking-ultra-wide text-moss">
                Aktivert
              </span>
            </div>
            <div class="mt-4 h-1 w-full overflow-hidden rounded bg-espresso-900/10">
              <div class="h-full w-full bg-moss"></div>
            </div>
            <p class="mt-2 font-sans text-[12px] text-espresso-600">
              Bilen kjører som planlagt
            </p>
          </div>

          <div class="rounded-lg border border-ember/30 bg-ember/5 p-6">
            <div class="flex items-center justify-between">
              <p class="font-display text-[20px] font-medium text-espresso-900">
                Eksempelstopp
              </p>
              <span class="font-sans text-[10px] uppercase tracking-ultra-wide text-ember">
                Ikke nok bestillinger
              </span>
            </div>
            <div class="mt-4 h-1 w-full overflow-hidden rounded bg-espresso-900/10">
              <div class="h-full w-[40%] bg-ember"></div>
            </div>
            <p class="mt-2 font-sans text-[12px] text-espresso-600">
              Du får valget om refusjon eller å bytte stopp
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- NOBEL-KREDITT -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Nobel-kreditt" align="center" />
        <h2 class="mt-8 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-6xl">
          En takk fra oss
          <br />
          <span class="display-italic text-brass-700">når du bestiller stort</span>.
        </h2>
        <p class="mt-8 font-sans text-[17px] leading-relaxed text-espresso-700">
          Bestiller du for et helgebesøk eller en feiring, gir vi tilbake en del
          av kjøpet som Nobel-kreditt til neste gang. Det er ikke en kupong eller
          rabatt — det er en bonus som dukker opp i appen din etter henting.
        </p>
      </div>

      <div class="mx-auto mt-16 max-w-3xl space-y-3" data-fade>
        {
          credit.map((c, i) => (
            <div class="flex items-center gap-6 rounded-lg border border-espresso-900/10 bg-cream-50 p-6 transition hover:border-brass-400/60">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-brass-300 bg-brass-50 font-display text-[18px] font-medium text-brass-700">
                {i + 1}
              </div>
              <div class="flex-1">
                <p class="font-sans text-[10px] uppercase tracking-ultra-wide text-brass-700">
                  Bestilling fra {c.tier}
                </p>
                <p class="mt-1 font-display text-[18px] font-medium text-espresso-900 sm:text-[20px]">
                  Du får {c.credit} i Nobel-kreditt
                </p>
                <p class="mt-1 font-sans text-[14px] text-espresso-600">{c.body}</p>
              </div>
              <div class="hidden font-display text-[44px] font-medium text-brass-700 sm:block">
                {c.credit}
              </div>
            </div>
          ))
        }
      </div>

      <p class="mx-auto mt-10 max-w-2xl text-center font-sans text-[14px] leading-relaxed text-espresso-600" data-fade>
        Krediten brukes som betalingsmiddel ved neste kjøp i appen, og er gyldig i
        90 dager. Ingen koder, ingen "husk å bruk denne på neste handel" — den
        ligger der og venter når du logger inn.
      </p>
    </div>
  </section>

  <CTABand
    eyebrow="Klar?"
    title="Last ned. Slå på varsler. Vi tar resten."
    body="Det tar et minutt å bli klar. Vi varsler deg når neste drop går live."
    primaryLabel="Bestill nå"
    secondaryHref="/produkter"
    secondaryLabel="Se hva vi baker"
  />
</BaseLayout>
