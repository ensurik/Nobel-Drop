---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import Photo from "~/components/Photo.astro";
import CTABand from "~/components/CTABand.astro";

const stops = [
  {
    num: "01",
    city: "Lier",
    type: "Samarbeidsstopp",
    detail: "Aktiveres når nok kunder i området har bestilt. Vi varsler i appen så snart stoppet er bekreftet.",
    status: "scout",
  },
  {
    num: "02",
    city: "Drammen",
    type: "Samarbeidsstopp",
    detail: "Sentralt knutepunkt midt i sentrum. Aktivt på utvalgte drops — sjekk i appen om det er åpent.",
    status: "scout",
  },
  {
    num: "03",
    city: "Holmestrand",
    type: "Fast stopp",
    detail: "Aktivt på alle drops. 90 minutter på stoppet, delt i tre 30-minutters vinduer du booker selv.",
    status: "active",
  },
  {
    num: "04",
    city: "Horten",
    type: "Fast stopp",
    detail: "Aktivt på alle drops. 90-minutters vindu med bookbare 30-min slots, maks 10 kunder per slot.",
    status: "active",
  },
  {
    num: "05",
    city: "Tønsberg",
    type: "Fast stopp",
    detail: "Siste stopp på ruten. Lengre opphold på utvalgte drops for å rekke flere kunder.",
    status: "active",
  },
];
---

<BaseLayout
  title="Hentesteder"
  description="Vi kjører Drammen til Tønsberg. Faste hentestopp med 30-minutters vinduer du booker i appen — ingen kø, ingen leveringsgebyr."
>
  <!-- HERO -->
  <section class="relative pt-12 pb-20 sm:pt-20 sm:pb-28">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end lg:gap-16">
        <div class="lg:col-span-7 lg:pb-8">
          <SectionLabel label="Hentesteder" />
          <h1
            class="mt-8 font-display text-[52px] font-medium leading-[0.98] tracking-tight text-espresso-900 sm:text-7xl lg:text-[88px]"
            data-fade
          >
            Vi kommer
            <br />
            <span class="display-italic text-brass-700">til ditt nabolag</span>.
          </h1>
          <p
            class="mt-10 max-w-xl font-sans text-[17px] leading-relaxed text-espresso-700 sm:text-[18px]"
            data-fade
          >
            Vi kjører den samme ruten — fra Drammen og ned langs Vestfold til
            Tønsberg. Velg ditt nærmeste stopp og et 30-minutters vindu i appen.
            Vi står klare når du kommer.
          </p>
        </div>

        <div class="lg:col-span-5" data-fade>
          <Photo
            src="/assets/pickup/van-tonsberg.jpg"
            alt="Nobel Drop-bilen ved et stopp i Vestfold"
            aspect="aspect-[4/5]"
            loading="eager"
            fetchpriority="high"
            fallbackLabel="Bilde · Bilen ved stoppet"
          />
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- KART -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div data-fade>
        <div class="relative aspect-[16/9] overflow-hidden rounded-lg border border-espresso-900/10 bg-cream-50 photo-frame">
          <svg
            class="absolute inset-0 h-full w-full"
            viewBox="0 0 1600 900"
            fill="none"
            preserveAspectRatio="xMidYMid slice"
            aria-hidden="true"
          >
            <g stroke="rgba(26,20,16,0.04)" stroke-width="1">
              {Array.from({ length: 30 }).map((_, i) => (
                <line x1={i * 60} y1="0" x2={i * 60} y2="900" />
              ))}
              {Array.from({ length: 18 }).map((_, i) => (
                <line x1="0" y1={i * 60} x2="1600" y2={i * 60} />
              ))}
            </g>

            <path
              d="M 120 480 Q 320 360 500 420 T 880 460 Q 1080 520 1280 540 T 1480 600"
              stroke="rgba(163,125,46,0.85)"
              stroke-width="2"
              fill="none"
            />
            <path
              d="M 120 480 Q 320 360 500 420 T 880 460 Q 1080 520 1280 540 T 1480 600"
              stroke="rgba(201,165,106,0.4)"
              stroke-width="6"
              fill="none"
              filter="blur(4px)"
            />

            <g>
              <circle cx="120" cy="480" r="7" fill="#F5F0E6" stroke="#A37D2E" stroke-width="2" />
              <text x="120" y="450" text-anchor="middle" fill="#3A2F22" font-size="14" font-family="Inter">Lier</text>
              <text x="120" y="510" text-anchor="middle" fill="#8C7C66" font-size="11" font-family="Inter" letter-spacing="2">SAMARBEID</text>

              <circle cx="450" cy="395" r="7" fill="#F5F0E6" stroke="#A37D2E" stroke-width="2" />
              <text x="450" y="365" text-anchor="middle" fill="#3A2F22" font-size="14" font-family="Inter">Drammen</text>
              <text x="450" y="425" text-anchor="middle" fill="#8C7C66" font-size="11" font-family="Inter" letter-spacing="2">SAMARBEID</text>

              <circle cx="780" cy="450" r="9" fill="#A37D2E" stroke="#1A1410" stroke-width="2" />
              <circle cx="780" cy="450" r="18" fill="none" stroke="rgba(163,125,46,0.4)" />
              <text x="780" y="420" text-anchor="middle" fill="#1A1410" font-size="15" font-family="Inter" font-weight="600">Holmestrand</text>
              <text x="780" y="490" text-anchor="middle" fill="#8B6722" font-size="11" font-family="Inter" letter-spacing="2">FAST STOPP</text>

              <circle cx="1080" cy="525" r="9" fill="#A37D2E" stroke="#1A1410" stroke-width="2" />
              <circle cx="1080" cy="525" r="18" fill="none" stroke="rgba(163,125,46,0.4)" />
              <text x="1080" y="495" text-anchor="middle" fill="#1A1410" font-size="15" font-family="Inter" font-weight="600">Horten</text>
              <text x="1080" y="565" text-anchor="middle" fill="#8B6722" font-size="11" font-family="Inter" letter-spacing="2">FAST STOPP</text>

              <circle cx="1380" cy="580" r="9" fill="#A37D2E" stroke="#1A1410" stroke-width="2" />
              <circle cx="1380" cy="580" r="18" fill="none" stroke="rgba(163,125,46,0.4)" />
              <text x="1380" y="550" text-anchor="middle" fill="#1A1410" font-size="15" font-family="Inter" font-weight="600">Tønsberg</text>
              <text x="1380" y="620" text-anchor="middle" fill="#8B6722" font-size="11" font-family="Inter" letter-spacing="2">FAST STOPP</text>
            </g>
          </svg>

          <div class="absolute right-6 top-6 flex items-center gap-2 font-sans text-[10px] uppercase tracking-ultra-wide text-espresso-500">
            <span>Sør</span>
            <span class="text-brass-600">→</span>
          </div>
        </div>
      </div>

      <p class="mx-auto mt-8 max-w-2xl text-center font-display text-[16px] italic text-espresso-600" data-fade>
        Faste stopp aktiveres på alle drops. Samarbeidsstopp aktiveres når nok
        bestillinger ligger inne — vi varsler deg i appen så snart vi vet.
      </p>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- LISTE -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl" data-fade>
        <SectionLabel label="Stoppene" />
        <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-5xl">
          Fra Lier til Tønsberg.
        </h2>
        <p class="mt-6 font-sans text-[16px] leading-relaxed text-espresso-700">
          Faste stopp har bookbare 30-minutters vinduer på alle drops.
          Samarbeidsstopp aktiveres når nok kunder i området har bestilt — det
          er sånn vi unngår at bilen står tom og delikatessene blir kjørt forgjeves.
        </p>
      </div>

      <div class="mt-16 divide-y divide-espresso-900/10 border-y border-espresso-900/10">
        {
          stops.map((r) => (
            <div class="grid grid-cols-12 items-center gap-4 px-2 py-8" data-fade>
              <div class="col-span-2 sm:col-span-1">
                <span class="font-display text-[28px] font-medium text-brass-600 sm:text-[44px]">
                  {r.num}
                </span>
              </div>
              <div class="col-span-10 sm:col-span-4">
                <p class="font-display text-[24px] font-medium text-espresso-900 sm:text-[28px]">
                  {r.city}
                </p>
                <p class="mt-1 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                  {r.type}
                </p>
              </div>
              <div class="col-span-12 sm:col-span-5">
                <p class="font-sans text-[14px] leading-relaxed text-espresso-700">
                  {r.detail}
                </p>
              </div>
              <div class="col-span-12 flex justify-start sm:col-span-2 sm:justify-end">
                {r.status === "active" ? (
                  <span class="inline-flex items-center gap-2 rounded-full border border-moss/30 bg-moss/5 px-3 py-1.5 font-sans text-[11px] uppercase tracking-ultra-wide text-moss">
                    <span class="h-1.5 w-1.5 rounded-full bg-moss" />
                    Alle drops
                  </span>
                ) : (
                  <span class="inline-flex items-center gap-2 rounded-full border border-espresso-900/15 px-3 py-1.5 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-600">
                    <span class="h-1.5 w-1.5 rounded-full bg-espresso-500" />
                    Etter etterspørsel
                  </span>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- TIDSVINDU -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Vinduene" align="center" />
        <h2 class="mt-8 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-6xl">
          Du booker tiden.
          <br />
          <span class="display-italic text-brass-700">Vi står klare.</span>
        </h2>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-3 gap-px bg-espresso-900/10 text-center" data-fade>
        <div class="bg-cream-50 px-4 py-12">
          <p class="font-display text-[64px] font-medium leading-none text-brass-700 sm:text-[88px]">
            90
          </p>
          <p class="mt-4 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
            Min på stoppet
          </p>
        </div>
        <div class="bg-cream-50 px-4 py-12">
          <p class="font-display text-[64px] font-medium leading-none text-brass-700 sm:text-[88px]">
            30
          </p>
          <p class="mt-4 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
            Min vinduer
          </p>
        </div>
        <div class="bg-cream-50 px-4 py-12">
          <p class="font-display text-[64px] font-medium leading-none text-brass-700 sm:text-[88px]">
            10
          </p>
          <p class="mt-4 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
            Maks per vindu
          </p>
        </div>
      </div>

      <p class="mx-auto mt-12 max-w-2xl text-center font-sans text-[16px] leading-relaxed text-espresso-700" data-fade>
        Vi setter en grense på 10 kunder per 30-minutters vindu. Det betyr at du
        aldri står i kø, og at vi får tid til å si hei. Maks tre minutter fra du
        parkerer til du kjører igjen.
      </p>
    </div>
  </section>

  <CTABand
    eyebrow="Velg ditt stopp"
    title="Bestill nå. Hent samme dag."
    body="Velg ditt nærmeste stopp i appen, lås tidsvinduet, og hent på 3 minutter."
    primaryLabel="Bestill nå"
    secondaryHref="/faq"
    secondaryLabel="Hva om jeg ikke rekker?"
  />
</BaseLayout>
