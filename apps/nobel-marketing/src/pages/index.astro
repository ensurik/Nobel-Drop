---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import Photo from "~/components/Photo.astro";
import TagPill from "~/components/TagPill.astro";
import CTABand from "~/components/CTABand.astro";
import IntroVideo from "~/components/IntroVideo.astro";

const products = [
  {
    title: "Signaturmakronen",
    line: "Hovedboksen",
    body: "Sprø skall, mykt indre. Brent karamell, mørk sjokolade, knust hasselnøtt og sesongens egen smak — pipet for hånd samme morgen som dropet.",
    image: "/assets/products/macron.jpg",
    fallback: "Bilde · Signaturmakronen",
  },
  {
    title: "Porsjonskaker",
    line: "For to og fire",
    body: "Petit four, sjokolademousse, sitronterte, bær på vanilje. Små desserter for søndagskaffen eller en stille kveld med noen du er glad i.",
    image: "/assets/products/porsjonskaker.jpg",
    fallback: "Bilde · Porsjonskaker",
  },
  {
    title: "Premiumkaken",
    line: "Hele kaker",
    body: "Bursdag, dåp, helgebesøk. Mandelbunn, friske bær, ekte krem — den slags kake du husker fra barndommen, fortsatt bakt på samme måte.",
    image: "/assets/products/premiumkake.jpg",
    fallback: "Bilde · Premiumkaken",
  },
  {
    title: "Middag i porsjon",
    line: "Kommer Q4",
    body: "Coq au vin, viltgryte, lakseretter — singel-pakket og klar for ovnen. Samme app, samme stopp, samme håndverk.",
    image: "/assets/products/middag.jpg",
    fallback: "Bilde · Middag i porsjon",
  },
];

const steps = [
  {
    num: "01",
    title: "Vi varsler",
    body: "Når et nytt drop er klart sender vi deg en push i appen. Du ser med en gang hva vi har bakt, hvor mange bokser som er igjen, og hvilke stopp som kjører.",
  },
  {
    num: "02",
    title: "Du velger",
    body: "Plukk boks. Legg til kake. Velg ditt nærmeste stopp og et 30-minutters vindu. Ett trykk Vipps eller Apple Pay, og du har en QR-kode i lomma.",
  },
  {
    num: "03",
    title: "Vi møtes",
    body: "På ditt valgte stopp i ditt valgte vindu. Vis QR — vi har boksen klar med navnet ditt på. Tre minutter, ut og inn. Hjemme før kaffen blir kald.",
  },
];

const occasions = [
  "Søndagskaffe",
  "Bursdag",
  "Helgebesøk",
  "Vertinnegave",
  "Dåp og feiring",
  "Etter en lang uke",
];
---

<BaseLayout title="Nobel Drop">
  <IntroVideo />

  <!-- ============== HERO ============== -->
  <section class="relative pt-12 pb-24 sm:pt-20 sm:pb-32">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end lg:gap-16">
        <!-- Left: hero copy -->
        <div class="lg:col-span-6 lg:pb-12">
          <p class="label-tiny mb-6" data-fade>
            Nobel Catering & Conditori — Bærum siden 1986
          </p>

          <h1
            class="font-display text-[52px] font-medium leading-[0.95] tracking-tight text-espresso-900 sm:text-7xl lg:text-[88px]"
            data-fade
          >
            Bakeriet
            <br />
            kommer
            <br />
            <span class="display-italic text-brass-700">til deg.</span>
          </h1>

          <p
            class="mt-10 max-w-md font-sans text-[17px] leading-relaxed text-espresso-700 sm:text-[18px]"
            data-fade
          >
            Friskbakte makroner og kaker fra et 39-årig konditori. Bestilt med
            ett trykk når et drop er klart, hentet på et stopp nær deg.
          </p>

          <div
            class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:items-center sm:gap-4"
            data-fade
          >
            <GoldButton href="https://shop.nobeldrop.no" variant="primary" size="lg">
              Bestill nå
            </GoldButton>
            <GoldButton href="/slik-fungerer-det" variant="ghost" size="lg" arrow={false}>
              Se hvordan det fungerer
            </GoldButton>
          </div>

          <div class="mt-12 flex flex-wrap gap-2.5" data-fade>
            <TagPill size="sm">Bakt fra bunnen siden 1986</TagPill>
            <TagPill size="sm">Bestill med ett trykk</TagPill>
            <TagPill size="sm">Hentet samme dag</TagPill>
          </div>
        </div>

        <!-- Right: hero photo -->
        <div class="lg:col-span-6" data-fade>
          <Photo
            src="/assets/hero/box-hero.jpg"
            alt="Nobel Drop-eske med gullfoliert logo, bakt for hånd"
            aspect="aspect-[4/5]"
            loading="eager"
            fetchpriority="high"
            fallbackLabel="Hero · Nobel Drop-eske"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ============== EDITORIAL OPENER ============== -->
  <section class="relative py-24 sm:py-32">
    <div class="container-prose text-center">
      <p class="label-tiny" data-fade>Hva er Nobel Drop</p>
      <p
        class="mt-8 font-display text-[28px] font-medium leading-[1.3] text-espresso-900 sm:text-[40px]"
        data-fade
      >
        Et konditori med en
        <span class="display-italic text-brass-700">ny dør</span>.
      </p>
      <p
        class="mt-8 font-sans text-[17px] leading-[1.7] text-espresso-700 sm:text-[18px]"
        data-fade
      >
        Nobel Catering & Conditori har bakt for Bærum og Østlandet i 39 år —
        bryllup, dåp, fredagsmiddager, kaker til konfirmasjon. Nobel Drop er
        den nyeste døren ut. Friskbakte bokser bestilt i appen, hentet på et
        stopp nær deg, alt fra det samme kjøkkenet.
      </p>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- ============== 3 STEG ============== -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="grid gap-16 lg:grid-cols-12 lg:gap-20">
        <div class="lg:col-span-4" data-fade>
          <SectionLabel label="Slik foregår det" />
          <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-5xl">
            Tre steg.
            <br />
            <span class="display-italic text-brass-700">Ingen friksjon.</span>
          </h2>
          <p class="mt-6 max-w-md font-sans text-[16px] leading-relaxed text-espresso-700">
            Vi har bygget bestillingen så enkel at den passer mellom kaffepausen
            og neste møte. Last ned, slå på varsler, og du er klar.
          </p>
          <div class="mt-8">
            <GoldButton href="/slik-fungerer-det" variant="ghost">
              Se hele flyten
            </GoldButton>
          </div>
        </div>

        <div class="lg:col-span-8">
          <ol class="space-y-12 sm:space-y-16">
            {
              steps.map((s, i) => (
                <li class="grid grid-cols-12 items-start gap-6" data-fade>
                  <div class="col-span-3 sm:col-span-2">
                    <span class="font-display text-[40px] font-medium leading-none text-brass-600 sm:text-6xl">
                      {s.num}
                    </span>
                  </div>
                  <div class="col-span-9 border-t border-espresso-900/10 pt-3 sm:col-span-10">
                    <h3 class="font-display text-[26px] font-medium leading-tight text-espresso-900 sm:text-[34px]">
                      {s.title}
                    </h3>
                    <p class="mt-3 max-w-xl font-sans text-[15px] leading-relaxed text-espresso-700 sm:text-[16px]">
                      {s.body}
                    </p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- ============== HVORFOR BEGRENSET (sensory) ============== -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-20">
        <div class="lg:col-span-6 lg:order-2" data-fade>
          <SectionLabel label="Bakt med tid" />
          <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-[60px]">
            Få bokser.
            <br />
            <span class="display-italic text-brass-700">Av en grunn.</span>
          </h2>
          <p class="mt-8 font-sans text-[17px] leading-[1.7] text-espresso-700 sm:text-[18px]">
            Vi baker et fast antall til hvert drop fordi vi vil at hver eneste
            makron skal være friskpiped samme morgen. Når de er borte, er de
            borte — det er ikke et triks, det er en konsekvens av hvordan vi
            jobber.
          </p>
          <p class="mt-5 font-sans text-[16px] leading-[1.7] text-espresso-700">
            Smør, ekte mandelmel, sjokolade fra produsenter vi har kjent i tjue
            år, bær fra norske leverandører. Pipet for hånd, bakt i ovner som
            fortsatt blir varme av to hender — ikke en knapp.
          </p>
        </div>

        <div class="lg:col-span-6 lg:order-1" data-fade>
          <Photo
            src="/assets/about/kitchen-hands.jpg"
            alt="Hender som piper makron-røre på pergament i Nobels kjøkken"
            aspect="aspect-[4/5]"
            fallbackLabel="Bilde · Hender på kjøkkenet"
          />
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- ============== BAKVERKET ============== -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto mb-20 max-w-3xl text-center" data-fade>
        <SectionLabel label="Bakverket" align="center" />
        <h2 class="mt-8 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-6xl">
          Det vi <span class="display-italic text-brass-700">faktisk baker</span>.
        </h2>
        <p class="mt-8 font-sans text-[17px] leading-relaxed text-espresso-700">
          Hovedboksen er signaturmakronen. Du kan legge til porsjonskaker for to,
          eller en hel kake til helgens besøk. Alt i samme bestilling.
        </p>
      </div>

      <div class="grid gap-x-8 gap-y-16 md:grid-cols-2">
        {
          products.map((p, i) => (
            <article class="group" data-fade>
              <Photo
                src={p.image}
                alt={p.title}
                aspect="aspect-[4/3]"
                fallbackLabel={p.fallback}
              />
              <div class="mt-6 flex items-baseline justify-between">
                <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-brass-700">
                  {p.line}
                </p>
                <span class="font-display text-sm italic text-espresso-500">
                  {String(i + 1).padStart(2, "0")} / 04
                </span>
              </div>
              <h3 class="mt-3 font-display text-[28px] font-medium leading-tight text-espresso-900 sm:text-[34px]">
                {p.title}
              </h3>
              <p class="mt-3 max-w-md font-sans text-[15px] leading-relaxed text-espresso-700 sm:text-[16px]">
                {p.body}
              </p>
            </article>
          ))
        }
      </div>

      <div class="mt-20 text-center" data-fade>
        <GoldButton href="/produkter" variant="ghost">
          Se hele bakverket
        </GoldButton>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- ============== ANLEDNINGER ============== -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-20">
        <div class="lg:col-span-7" data-fade>
          <Photo
            src="/assets/lifestyle/sunday-table.jpg"
            alt="Søndagsbord med kaffe og en åpnet boks med makroner"
            aspect="aspect-[5/4]"
            fallbackLabel="Bilde · Søndagsbord"
          />
        </div>

        <div class="lg:col-span-5" data-fade>
          <SectionLabel label="Når det smaker best" />
          <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-[52px]">
            For hverdag og
            <br />
            <span class="display-italic text-brass-700">små feiringer</span>.
          </h2>
          <p class="mt-8 font-sans text-[16px] leading-relaxed text-espresso-700">
            En boks i fanget på fredagskvelden. Søndagskaffen med en porsjonskake
            til to. Vertinnegaven du tok med fordi du visste den var bakt fra
            bunnen.
          </p>

          <div class="mt-8 flex flex-wrap gap-2">
            {occasions.map((o) => <TagPill size="sm">{o}</TagPill>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- ============== HISTORIE / ARV ============== -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-20">
        <div class="lg:col-span-5" data-fade>
          <SectionLabel label="Om Nobel" />
          <h2 class="mt-6 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-[52px]">
            Det startet
            <br />
            <span class="display-italic text-brass-700">i Nobelsgate 23.</span>
          </h2>
          <p class="mt-8 font-sans text-[16px] leading-[1.7] text-espresso-700">
            I 1986 åpnet to gründere et lite konditori midt i Oslo. De hadde
            verken stort budsjett eller en plan om å bli store — bare en idé om
            at det fantes plass for noen som baket kakene fra bunnen, hver
            morgen. Adressen ga navnet, og navnet har stått siden.
          </p>
          <p class="mt-5 font-sans text-[16px] leading-[1.7] text-espresso-700">
            I dag er det rundt 40 hender på kjøkkenene i Bærum og på Skedsmokorset.
            Miljøfyrtårn-sertifisert. Hele leveringsflåten elektrisk.
          </p>
          <div class="mt-8">
            <GoldButton href="/om-nobel" variant="ghost">
              Les hele historien
            </GoldButton>
          </div>
        </div>

        <div class="lg:col-span-7" data-fade>
          <div class="grid grid-cols-2 gap-px bg-espresso-900/10">
            <div class="bg-cream-50 p-8 sm:p-10">
              <p class="font-display text-[56px] font-medium leading-none text-brass-700 sm:text-[72px]">
                1986
              </p>
              <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                Etablert
              </p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-espresso-600">
                Nobelsgate 23, Oslo. To gründere, dag og natt.
              </p>
            </div>
            <div class="bg-cream-50 p-8 sm:p-10">
              <p class="font-display text-[56px] font-medium leading-none text-brass-700 sm:text-[72px]">
                39 år
              </p>
              <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                Siden
              </p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-espresso-600">
                Samme oppskrifter. Større ovner. Flere bryllup.
              </p>
            </div>
            <div class="bg-cream-50 p-8 sm:p-10">
              <p class="font-display text-[56px] font-medium leading-none text-brass-700 sm:text-[72px]">
                ~40
              </p>
              <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                Hender på kjøkkenet
              </p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-espresso-600">
                Bakere, konditorer, kjøkkensjefer. Faste hender.
              </p>
            </div>
            <div class="bg-cream-50 p-8 sm:p-10">
              <p class="font-display text-[56px] font-medium leading-none text-brass-700 sm:text-[72px]">
                100 %
              </p>
              <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                Elektrisk kjøring
              </p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-espresso-600">
                Miljøfyrtårn-sertifisert. Lokale råvarer der vi kan.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- ============== HENTESTEDER ============== -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Hentesteder" align="center" />
        <h2 class="mt-8 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-6xl">
          Vi kommer dit
          <br />
          <span class="display-italic text-brass-700">du allerede er</span>.
        </h2>
        <p class="mt-8 font-sans text-[17px] leading-relaxed text-espresso-700">
          Faste stopp fra Drammen og ned langs Vestfold. Du velger ditt nærmeste,
          og et 30-minutters vindu som passer deg.
        </p>
      </div>

      <div class="mx-auto mt-16 max-w-5xl" data-fade>
        <div class="grid grid-cols-5 gap-px bg-espresso-900/10 text-center">
          {
            ["Lier", "Drammen", "Holmestrand", "Horten", "Tønsberg"].map(
              (city, i) => (
                <div class="bg-cream-50 px-2 py-7 sm:py-12">
                  <p class="font-display text-[28px] font-medium text-brass-700 sm:text-[44px]">
                    {String(i + 1).padStart(2, "0")}
                  </p>
                  <p class="mt-3 font-display text-[15px] font-medium text-espresso-900 sm:text-[20px]">
                    {city}
                  </p>
                  <p class="mt-1.5 font-sans text-[10px] uppercase tracking-ultra-wide text-espresso-500 sm:text-[11px]">
                    {i < 2 ? "Samarbeid" : "Fast stopp"}
                  </p>
                </div>
              )
            )
          }
        </div>
      </div>

      <div class="mt-12 text-center" data-fade>
        <GoldButton href="/hentesteder" variant="ghost">
          Se kart og tider
        </GoldButton>
      </div>
    </div>
  </section>

  <CTABand />
</BaseLayout>
