          Send stemme
          <svg class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M2 6h8M7 2l4 4-4 4" />
          </svg>
        </button>
      </form>

      <p class="mx-auto mt-6 max-w-xl text-center font-sans text-[12px] uppercase tracking-ultra-wide text-espresso-500" data-fade>
