---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SectionLabel from "~/components/SectionLabel.astro";

const sections = [
  {
    title: "Avtalen",
    body: "Når du bestiller via Nobel Drop, inngår du en kjøpsavtale med Nobel Catering & Conditori AS (org.nr. 931 878 409). Disse vilkårene gjelder alle kjøp gjennom appen og web-bestilling.",
  },
  {
    title: "Bestilling og betaling",
    body: "Alle bestillinger er forhåndsbetalt. Reservasjonen er gyldig i 20 sekunder etter du legger til varer i handlekurven. Hvis betaling ikke fullføres innenfor dette vinduet, frigjøres plassen automatisk. Bestillingen anses som bindende først når betaling er bekreftet.",
  },
  {
    title: "Henting",
    body: "Du må hente bestillingen i ditt valgte 90-minutters pickup-vindu på den noden du valgte i appen. Manglende henting i vinduet gir ikke automatisk rett til refusjon — kontakt oss på hello@nobeldrop.no så finner vi en løsning.",
  },
  {
    title: "Volumstyrt levering",
    body: "Vi forbeholder oss retten til å avlyse pickup-stopp som ikke når minimumsvolum innen cutoff (typisk 12 timer før hentevinduet). Ved avlysning får du valget mellom (a) full refusjon, eller (b) flytting til en annen aktiv pickup-node.",
  },
  {
    title: "Refusjon og angrerett",
    body: "Som hovedregel gjelder ikke angrerettloven for matvarer som er bestilt for et spesifikt tidspunkt og produsert på forhåndsordre. Refusjon gis ved (i) avlyst pickup-stopp som beskrevet over, eller (ii) reklamasjon ved feil eller mangel på produktet.",
  },
  {
    title: "Nobel-kreditt",
    body: "Nobel-kreditt utløses automatisk på ordrer over 1 000 / 1 500 / 2 000 kr (10 / 15 / 20 %). Krediten har gyldighet i 90 dager fra utstedelse, brukes som betalingsmiddel i appen, og kan ikke veksles til kontanter. Krediten følger kontoen og er personlig.",
  },
  {
    title: "Begrensning av ansvar",
    body: "Nobel Catering & Conditori er ansvarlig for produktets kvalitet ved overlevering. Skader oppstått etter henting (for eksempel transportskade hjem) dekkes ikke. Vi er ikke ansvarlige for indirekte tap eller følgeskader.",
  },
  {
    title: "Endringer",
    body: "Vi kan oppdatere disse vilkårene fra tid til annen. Vesentlige endringer varsles via app og e-post minst 14 dager før de trer i kraft.",
  },
];
---

<BaseLayout
  title="Vilkår"
  description="Brukervilkår for kjøp via Nobel Drop. Bestilling, betaling, pickup, refusjon, og Nobel-kreditt."
>
  <section class="relative pt-12 pb-16 sm:pt-20 sm:pb-24">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl">
        <SectionLabel label="Vilkår" />
        <h1 class="mt-8 font-display text-[44px] font-medium leading-[1.05] text-espresso-900 sm:text-6xl lg:text-7xl" data-fade>
          Brukervilkår
        </h1>
        <p class="mt-8 font-sans text-[14px] text-espresso-500" data-fade>
          Sist oppdatert: {new Date().toLocaleDateString("nb-NO", { day: "numeric", month: "long", year: "numeric" })}
        </p>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <section class="relative py-20 sm:py-28">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl space-y-12">
        {
          sections.map((s, i) => (
            <div data-fade>
              <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-brass-700">
                §{String(i + 1).padStart(2, "0")}
              </p>
              <h2 class="mt-3 font-display text-[28px] font-medium leading-tight text-espresso-900 sm:text-[34px]">
                {s.title}
              </h2>
              <p class="mt-5 font-sans text-[16px] leading-[1.7] text-espresso-700">
                {s.body}
              </p>
            </div>
          ))
        }

        <div class="border-t border-espresso-900/10 pt-8" data-fade>
          <p class="font-sans text-[14px] text-espresso-600">
            Spørsmål til vilkårene? Skriv til{" "}
            <a href="mailto:hello@nobeldrop.no" class="link-brass">
              hello@nobeldrop.no
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
