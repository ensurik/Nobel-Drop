---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import CTABand from "~/components/CTABand.astro";

const groups = [
  {
    label: "Bestilling",
    items: [
      {
        q: "Hvordan vet jeg når neste drop er?",
        a: "Last ned appen og slå på push-varsler. Hvert drop går live fredag kl. 10:00. Du blir varslet i samme sekund som det er åpent.",
      },
      {
        q: "Hvor mange er det av hvert drop?",
        a: "Begrenset antall. Det varierer per drop, men telleren i appen viser alltid hvor mange bokser som er igjen i sanntid. Når den når null, er den null.",
      },
      {
        q: "Kan jeg reservere på forhånd?",
        a: "Nei. Hele poenget med drop-mekanikken er at alle starter på samme linje. Den eneste måten å sikre seg på er å være rask når dropet går live.",
      },
      {
        q: "Hva er minimumsordren?",
        a: "396 kroner — som tilsvarer én 4-pakk signaturmakron. Vi setter et tak fordi mikroordrer ikke gir grunnlag for håndverkskvaliteten du betaler for.",
      },
    ],
  },
  {
    label: "Betaling & kreditt",
    items: [
      {
        q: "Hvilke betalingsmetoder kan jeg bruke?",
        a: "Vipps eCom, Apple Pay og Klarna. Alle metoder er 100 % forhåndsbetalt — pengene reserveres før produksjonen starter.",
      },
      {
        q: "Hva er Nobel-kreditt?",
        a: "Bestiller du for over 1 000 kr får du 10 % i Nobel-kreditt. Over 1 500 kr — 15 %. Over 2 000 kr — 20 %. Krediten brukes som betalingsmiddel ved neste kjøp og utløper etter 90 dager.",
      },
      {
        q: "Hvorfor gir dere ikke bare rabatt?",
        a: "Rabatt svekker premium-følelsen og signaliserer at prisen var oppblåst. Kreditt belønner gjenkjøp uten å ødelegge merkevaren. Det er et bevisst valg.",
      },
      {
        q: "Hva skjer hvis jeg ikke fullfører betalingen?",
        a: "Reservasjonen utløper på 20 sekunder. Etter det frigjøres plassen til neste kunde. Du får ingen ordre, ingen ladning.",
      },
    ],
  },
  {
    label: "Henting & pickup",
    items: [
      {
        q: "Hvor henter jeg ordren?",
        a: "Du velger pickup-node i appen — Holmestrand, Horten eller Tønsberg er våre faste 90-minutters stopp. Drammen og Lier aktiveres datadrevet.",
      },
      {
        q: "Hvor lang er hentevinduet?",
        a: "90 minutter, delt i tre 30-minutters slots. Du velger slot ved bestilling, og maks 10 kunder bookes per slot. Det betyr 3 minutter per kunde.",
      },
      {
        q: "Hva om jeg ikke rekker hentevinduet?",
        a: "Hentevinduet er fast. Hvis du ikke rekker det, kan vi dessverre ikke holde varene. Send oss en e-post på hello@nobeldrop.no — vi finner en løsning fra sak til sak.",
      },
      {
        q: "Hvordan skanner dere ordren min?",
        a: "Du får en HMAC-signert QR-kode i appen så snart betalingen er bekreftet. Sjåføren skanner den, og bekreftelsen er øyeblikkelig.",
      },
    ],
  },
  {
    label: "Volum & refusjon",
    items: [
      {
        q: "Hva betyr 'volumstyrt levering'?",
        a: "Hver pickup-node krever et minimumsvolum. Hvis ikke nok kunder bestiller fra samme node innen cutoff (typisk 12 timer før vinduet), går vi ikke dit.",
      },
      {
        q: "Hva skjer da med min ordre?",
        a: "Hele beløpet refunderes automatisk, eller du kan velge å flytte ordren til en annen node som har nådd minimumsvolum. Du blir varslet i appen.",
      },
      {
        q: "Hvorfor gjør dere det slik?",
        a: "Null tomkjøring. Du sparer penger fordi vi ikke betaler for bil + sjåfør til områder uten kjøpekraft, og du sparer planeten — vi kjører kun der vi vet det er reell etterspørsel.",
      },
    ],
  },
  {
    label: "Om Nobel",
    items: [
      {
        q: "Hvem står bak Nobel Drop?",
        a: "Nobel Catering & Conditori, etablert i 1986 ved Nobelsgate 23 i Oslo. Vi har rundt 40 ansatte og leverer i hele Østlandet — i tillegg til catering, bryllup, bedriftsarrangementer og kakebestillinger.",
      },
      {
        q: "Er det det samme som nobelcatering.no?",
        a: "Ja. Nobel Drop er Nobel Caterings nye D2C-kanal — bygget oppå samme kjøkken, samme håndverk, samme leverandørkjede. Tradisjonell catering finner du fortsatt på nobelcatering.no.",
      },
      {
        q: "Er produktene bærekraftige?",
        a: "Vi er sertifisert miljøfyrtårn. Hele leveringsflåten går elektrisk. Råvarer er lokalt og økologisk der det er mulig. Drop-mekanikken eliminerer i tillegg svinn — vi produserer kun mot låste forhåndsordrer.",
      },
    ],
  },
];
---

<BaseLayout
  title="FAQ"
  description="Svar på de vanligste spørsmålene om Nobel Drop: drops, betaling, Nobel-kreditt, pickup-mekanikk, refusjon, og hvem som står bak."
>
  <!-- HERO -->
  <section class="relative overflow-hidden pt-24 pb-24 sm:pt-36 sm:pb-32">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(200,162,76,0.06)_0%,transparent_55%)]"
      aria-hidden="true"
    >
    </div>
    <div class="container-edge relative">
      <div class="mx-auto max-w-3xl">
        <SectionLabel label="Vanlige spørsmål" />
        <h1
          class="mt-8 font-display text-5xl leading-[1.02] text-bone-100 sm:text-7xl lg:text-[88px]"
          data-fade
        >
          Alt du lurer på<br /><span class="italic text-shimmer">før du klikker</span>.
        </h1>
        <p class="mt-10 max-w-2xl font-sans text-lg leading-relaxed text-bone-300" data-fade>
          Drops, pickup, betaling, kreditt, refusjon. De vanligste spørsmålene — samlet.
        </p>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- FAQ GRUPPER -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-4xl space-y-20">
        {
          groups.map((g) => (
            <div data-fade>
              <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-gold-200/80">
                {g.label}
              </p>
              <div class="mt-2 h-px w-full bg-gold-400/30" />

              <div class="mt-2 divide-y divide-ink-600/60">
                {g.items.map((item) => (
                  <details class="group py-6">
                    <summary class="flex cursor-pointer list-none items-start justify-between gap-6 text-left">
                      <h3 class="font-display text-xl text-bone-100 transition group-hover:text-gold-200 sm:text-2xl">
                        {item.q}
                      </h3>
                      <span
                        class="mt-2 flex h-6 w-6 shrink-0 items-center justify-center border border-gold-400/40 text-gold-200 transition group-open:rotate-45"
                        aria-hidden="true"
                      >
                        +
                      </span>
                    </summary>
                    <p class="mt-4 max-w-3xl font-sans text-base leading-relaxed text-bone-300">
                      {item.a}
                    </p>
                  </details>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Spørsmål utenom listen?"
    title="Vi svarer alle, alltid."
    body="Send oss en mail på hello@nobeldrop.no, eller åpne appen og chat oss direkte."
    primaryLabel="Åpne app"
    secondaryHref="/kontakt"
    secondaryLabel="Kontakt oss"
  />
</BaseLayout>
