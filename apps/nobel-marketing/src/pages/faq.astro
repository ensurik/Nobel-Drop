---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import CTABand from "~/components/CTABand.astro";

const groups = [
  {
    label: "Bestilling",
    items: [
      {
        q: "Når og hvor ofte er det drops?",
        a: "Hver fredag kl. 10:00. Vi sender push-varsel i samme sekund dropet går live, slik at du blir varslet med en gang du har slått det på i appen.",
      },
      {
        q: "Hvor mange bokser er det per drop?",
        a: "Det varierer mellom 100 og 250 bokser per uke, avhengig av hvor mye vi rekker å bake samme morgen. Tellverket i appen viser hvor mange som er igjen i sanntid.",
      },
      {
        q: "Kan jeg reservere på forhånd?",
        a: "Nei. Hele poenget er at alle starter på samme linje. Den eneste måten å sikre seg på er å være klar når klokka slår 10:00 fredag morgen.",
      },
      {
        q: "Hva er minimum jeg kan bestille for?",
        a: "396 kroner — det tilsvarer én 4-pakk signaturmakron. Vi setter denne grensen fordi mikroordrer ikke kan leveres på premium-måten vi vil holde.",
      },
    ],
  },
  {
    label: "Betaling og kreditt",
    items: [
      {
        q: "Hvilke betalingsmåter støtter dere?",
        a: "Vipps, Apple Pay og Klarna. Alle krever at du betaler i forveien. Pengene reserveres med en gang, men du blir ikke trukket før vi har bakt boksen din.",
      },
      {
        q: "Hva er Nobel-kreditt?",
        a: "Bestiller du for over 1 000 kr får du 10 % i kreditt til neste fredag. Over 1 500 kr — 15 %. Over 2 000 kr — 20 %. Krediten dukker opp i appen etter at du har hentet ordren, og brukes som betaling neste gang.",
      },
      {
        q: "Hvorfor får jeg kreditt og ikke rabatt?",
        a: "Det er en takk vi gir tilbake til faste kunder. Krediten er gyldig i 90 dager, slik at du har god tid til å bruke den, og kommer aldri som en avslag-pris.",
      },
      {
        q: "Hva skjer hvis jeg ikke fullfører betalingen?",
        a: "Reservasjonen utløper på 20 sekunder. Etter det frigjøres plassen til neste kunde, og du må starte på nytt — som regel er det fortsatt bokser igjen, men ingen garanti.",
      },
    ],
  },
  {
    label: "Henting og pickup",
    items: [
      {
        q: "Hvor henter jeg ordren?",
        a: "Du velger ditt nærmeste stopp i appen — Holmestrand, Horten eller Tønsberg er våre faste stopp hver fredag. Drammen og Lier er samarbeidsstopp som åpnes når nok kunder i området har bestilt.",
      },
      {
        q: "Hvor lenge står dere på stoppet?",
        a: "90 minutter per stopp, delt i tre 30-minutters vinduer. Du booker det vinduet som passer deg best, og det er maks 10 kunder per vindu — så ingen kø.",
      },
      {
        q: "Hva om jeg ikke rekker hentevinduet?",
        a: "Hentevinduet er fast. Hvis du ikke rekker det, kan vi dessverre ikke holde varene. Send oss en e-post på hello@nobeldrop.no — vi finner alltid en løsning fra sak til sak.",
      },
      {
        q: "Hvordan vet sjåføren at det er meg?",
        a: "Du får en QR-kode i appen så snart betalingen er bekreftet. Vis koden på stoppet, så har vi boksen din klar. Du trenger ikke si navnet ditt.",
      },
    ],
  },
  {
    label: "Hvis ditt stopp ikke aktiveres",
    items: [
      {
        q: "Hva betyr det at et stopp 'aktiveres'?",
        a: "Hvert hentested har en grense for hvor mange bestillinger vi trenger for at det skal være verdt å sette seg i bilen — typisk 12 timer før vinduet sjekker vi om vi er der.",
      },
      {
        q: "Hva skjer hvis stoppet mitt ikke aktiveres?",
        a: "Du får et push-varsel og kan velge mellom (a) full refusjon med en gang, eller (b) flytte ordren til et annet aktivt stopp uten ekstra kostnad. Du bestemmer.",
      },
      {
        q: "Hvorfor gjør dere det slik?",
        a: "Det er fordi vi vil holde leveringen ærlig. Vi kjører ikke en halvtom bil til et stopp uten kunder — det betyr ferskere bakverk, mindre transport, og at vi kan teste nye områder uten at noen taper på det.",
      },
    ],
  },
  {
    label: "Om Nobel og bakverket",
    items: [
      {
        q: "Hvem står bak Nobel Drop?",
        a: "Nobel Catering & Conditori, etablert 1986 i Nobelsgate 23 i Oslo. Vi har rundt 40 ansatte og kjøkken i Bærum og på Skedsmokorset, og leverer mat og kaker til hele Østlandet.",
      },
      {
        q: "Er det det samme som nobelcatering.no?",
        a: "Ja. Nobel Drop er den samme bedriften, bare en ny måte å nå deg på. Tradisjonell catering — bryllup, dåp, konfirmasjon, bedriftsarrangement — finner du fortsatt på nobelcatering.no.",
      },
      {
        q: "Er bakverket ferskt?",
        a: "Det er bakt samme morgen som dropet. Forhåndsbetalingen lar oss bake nøyaktig det vi trenger, så ingenting blir liggende fra dagen før. Du henter samme dag som det er bakt.",
      },
      {
        q: "Bruker dere lokale råvarer?",
        a: "Så langt det er mulig. Vi har vært miljøfyrtårn-sertifisert lenge, hele leveringsflåten er elektrisk, og vi prioriterer lokalt og økologisk der det finnes. Drop-modellen reduserer i tillegg svinn — vi baker mot låste bestillinger.",
      },
    ],
  },
];
---

<BaseLayout
  title="FAQ"
  description="Svar på de vanligste spørsmålene om Nobel Drop: når er dropet, hvordan henter jeg, hva om stoppet ikke aktiveres, hva er Nobel-kreditt."
>
  <!-- HERO -->
  <section class="relative overflow-hidden pt-24 pb-24 sm:pt-36 sm:pb-32">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(200,162,76,0.06)_0%,transparent_55%)]"
      aria-hidden="true"
    >
    </div>
    <div class="container-edge relative">
      <div class="mx-auto max-w-3xl">
        <SectionLabel label="Vanlige spørsmål" />
        <h1
          class="mt-8 font-display text-5xl leading-[1.02] text-bone-100 sm:text-7xl lg:text-[88px]"
          data-fade
        >
          Det folk lurer på<br /><span class="italic text-shimmer">før de bestiller</span>.
        </h1>
        <p class="mt-10 max-w-2xl font-sans text-lg leading-relaxed text-bone-300" data-fade>
          Drops, betaling, henting, refusjon. Det meste er enklere enn det høres ut som —
          her er svarene.
        </p>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- FAQ GRUPPER -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-4xl space-y-20">
        {
          groups.map((g) => (
            <div data-fade>
              <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-gold-200/80">
                {g.label}
              </p>
              <div class="mt-2 h-px w-full bg-gold-400/30" />

              <div class="mt-2 divide-y divide-ink-600/60">
                {g.items.map((item) => (
                  <details class="group py-6">
                    <summary class="flex cursor-pointer list-none items-start justify-between gap-6 text-left">
                      <h3 class="font-display text-xl text-bone-100 transition group-hover:text-gold-200 sm:text-2xl">
                        {item.q}
                      </h3>
                      <span
                        class="mt-2 flex h-6 w-6 shrink-0 items-center justify-center border border-gold-400/40 text-gold-200 transition group-open:rotate-45"
                        aria-hidden="true"
                      >
                        +
                      </span>
                    </summary>
                    <p class="mt-4 max-w-3xl font-sans text-base leading-relaxed text-bone-300">
                      {item.a}
                    </p>
                  </details>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Mangler det noe?"
    title="Vi svarer alle, alltid."
    body="Send oss en mail på hello@nobeldrop.no, eller åpne appen og chat oss direkte."
    primaryLabel="Last ned appen"
    secondaryHref="/kontakt"
    secondaryLabel="Kontakt oss"
  />
</BaseLayout>
