---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import CTABand from "~/components/CTABand.astro";

const groups = [
  {
    label: "Bestilling",
    items: [
      {
        q: "Når er det drops?",
        a: "Vi varsler i appen så snart neste drop er live. Drops kan komme én eller flere ganger i uken — det avhenger av hva vi baker. Slå på push så du blir varslet i samme sekund.",
      },
      {
        q: "Hvor mange bokser er det per drop?",
        a: "Det varierer mellom 100 og 250 bokser, avhengig av hvor mye vi rekker å bake samme morgen. Tellverket i appen viser hvor mange som er igjen i sanntid.",
      },
      {
        q: "Kan jeg reservere på forhånd?",
        a: "Nei. Hele poenget er at alle starter på samme linje. Den eneste måten å sikre seg på er å være klar når dropet går live.",
      },
      {
        q: "Hva er minimum jeg kan bestille for?",
        a: "396 kroner — det tilsvarer én 4-pakk signaturmakron. Vi setter denne grensen fordi mikroordrer ikke kan leveres på premium-måten vi vil holde.",
      },
    ],
  },
  {
    label: "Betaling og kreditt",
    items: [
      {
        q: "Hvilke betalingsmåter støtter dere?",
        a: "Vipps, Apple Pay og Klarna. Alle krever forhåndsbetaling. Pengene reserveres med en gang, men du blir ikke trukket før vi har bakt boksen din.",
      },
      {
        q: "Hva er Nobel-kreditt?",
        a: "Bestiller du for over 1 000 kr, får du 10 % tilbake i Nobel-kreditt til neste gang. Over 1 500 kr — 15 %. Over 2 000 kr — 20 %. Krediten dukker opp i appen etter at du har hentet ordren.",
      },
      {
        q: "Hvorfor får jeg kreditt og ikke rabatt?",
        a: "Det er en takk vi gir tilbake til faste kunder. Krediten er gyldig i 90 dager, slik at du har god tid til å bruke den, og kommer aldri som en avslagspris.",
      },
      {
        q: "Hva skjer hvis jeg ikke fullfører betalingen?",
        a: "Reservasjonen utløper på 20 sekunder. Etter det frigjøres plassen til neste kunde, og du må starte på nytt — som regel er det fortsatt bokser igjen, men ingen garanti.",
      },
    ],
  },
  {
    label: "Henting og pickup",
    items: [
      {
        q: "Hvor henter jeg ordren?",
        a: "Du velger ditt nærmeste stopp i appen — Holmestrand, Horten eller Tønsberg er våre faste stopp. Drammen og Lier er samarbeidsstopp som åpnes når nok kunder i området har bestilt.",
      },
      {
        q: "Hvor lenge står dere på stoppet?",
        a: "90 minutter per stopp, delt i tre 30-minutters vinduer. Du booker det vinduet som passer deg best, og det er maks 10 kunder per vindu — så ingen kø.",
      },
      {
        q: "Hva om jeg ikke rekker hentevinduet?",
        a: "Hentevinduet er fast. Hvis du ikke rekker det, kan vi dessverre ikke holde varene. Send oss en e-post på hello@nobeldrop.no — vi finner alltid en løsning fra sak til sak.",
      },
      {
        q: "Hvordan vet sjåføren at det er meg?",
        a: "Du får en QR-kode i appen så snart betalingen er bekreftet. Vis koden på stoppet, så har vi boksen din klar. Du trenger ikke si navnet ditt.",
      },
    ],
  },
  {
    label: "Hvis ditt stopp ikke aktiveres",
    items: [
      {
        q: "Hva betyr det at et stopp 'aktiveres'?",
        a: "Hvert hentested har en grense for hvor mange bestillinger vi trenger for at det skal være verdt å sette seg i bilen — typisk 12 timer før vinduet sjekker vi om vi er der.",
      },
      {
        q: "Hva skjer hvis stoppet mitt ikke aktiveres?",
        a: "Du får et push-varsel og kan velge mellom (a) full refusjon med en gang, eller (b) flytte ordren til et annet aktivt stopp uten ekstra kostnad. Du bestemmer.",
      },
      {
        q: "Hvorfor gjør dere det slik?",
        a: "Det er fordi vi vil holde leveringen ærlig. Vi kjører ikke en halvtom bil til et stopp uten kunder — det betyr ferskere bakverk, mindre transport, og at vi kan teste nye områder uten at noen taper på det.",
      },
    ],
  },
  {
    label: "Om Nobel og bakverket",
    items: [
      {
        q: "Hvem står bak Nobel Drop?",
        a: "Nobel Catering & Conditori, etablert 1986 i Nobelsgate 23 i Oslo. Vi har rundt 40 ansatte og kjøkken i Bærum og på Skedsmokorset, og leverer mat og kaker til hele Østlandet.",
      },
      {
        q: "Er det det samme som nobelcatering.no?",
        a: "Ja. Nobel Drop er den samme bedriften, bare en ny måte å nå deg på. Tradisjonell catering — bryllup, dåp, konfirmasjon, bedriftsarrangement — finner du fortsatt på nobelcatering.no.",
      },
      {
        q: "Er bakverket ferskt?",
        a: "Det er bakt samme dag som dropet. Forhåndsbetalingen lar oss bake nøyaktig det vi trenger, så ingenting blir liggende fra dagen før. Du henter samme dag som det er bakt.",
      },
      {
        q: "Bruker dere lokale råvarer?",
        a: "Så langt det er mulig. Vi har vært miljøfyrtårn-sertifisert lenge, hele leveringsflåten er elektrisk, og vi prioriterer lokalt og økologisk der det finnes.",
      },
    ],
  },
];
---

<BaseLayout
  title="FAQ"
  description="Svar på de vanligste spørsmålene om Nobel Drop: når er dropet, hvordan henter jeg, hva om stoppet ikke aktiveres, hva er Nobel-kreditt."
>
  <!-- HERO -->
  <section class="relative pt-12 pb-20 sm:pt-20 sm:pb-28">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl">
        <SectionLabel label="Vanlige spørsmål" />
        <h1
          class="mt-8 font-display text-[52px] font-medium leading-[0.98] tracking-tight text-espresso-900 sm:text-7xl lg:text-[80px]"
          data-fade
        >
          Det folk lurer på
          <br />
          <span class="display-italic text-brass-700">før de bestiller</span>.
        </h1>
        <p
          class="mt-10 max-w-xl font-sans text-[17px] leading-relaxed text-espresso-700 sm:text-[18px]"
          data-fade
        >
          Drops, betaling, henting, refusjon. Det meste er enklere enn det høres
          ut som — her er svarene.
        </p>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- FAQ GRUPPER -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="mx-auto max-w-4xl space-y-20">
        {
          groups.map((g) => (
            <div data-fade>
              <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-brass-700">
                {g.label}
              </p>
              <div class="mt-2 h-px w-full bg-espresso-900/10" />

              <div class="mt-2 divide-y divide-espresso-900/10">
                {g.items.map((item) => (
                  <details class="group py-6">
                    <summary class="flex cursor-pointer list-none items-start justify-between gap-6 text-left">
                      <h3 class="font-display text-[20px] font-medium leading-tight text-espresso-900 transition group-hover:text-brass-700 sm:text-[24px]">
                        {item.q}
                      </h3>
                      <span
                        class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-brass-300 text-brass-700 transition group-open:rotate-45"
                        aria-hidden="true"
                      >
                        +
                      </span>
                    </summary>
                    <p class="mt-4 max-w-3xl font-sans text-[15px] leading-relaxed text-espresso-700 sm:text-[16px]">
                      {item.a}
                    </p>
                  </details>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Mangler det noe?"
    title="Vi svarer alle, alltid."
    body="Send oss en mail på hello@nobeldrop.no, eller åpne appen og chat oss direkte."
    primaryLabel="Bestill nå"
    secondaryHref="/kontakt"
    secondaryLabel="Kontakt oss"
  />
</BaseLayout>
