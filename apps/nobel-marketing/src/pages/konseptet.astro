---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import HairlineFrame from "~/components/HairlineFrame.astro";
import CTABand from "~/components/CTABand.astro";

const flowSteps = [
  {
    num: "1",
    title: "Varsel",
    body: "Push-varsel fredag kl. 10:00. Begrenset antall lansert. Knapphet er ikke en hilsen — det er starten på klokka.",
  },
  {
    num: "2",
    title: "Velg",
    body: "Kunden legger hero-produktet i handlekurven. Sortiment opt-in til kurv-byggere og ordreløftere når hoveddropet er sikret.",
  },
  {
    num: "3",
    title: "Betaling",
    body: "1-klikks forhåndsbetaling via Vipps eller Apple Pay. 100 % paid før et eneste råvare forlater kjøkkenet.",
  },
  {
    num: "4",
    title: "Tidsvindu",
    body: "Velg et tydelig 90-minutters hentevindu på en fast pickup-node. Maks 10 kunder per 30-minutters slot.",
  },
  {
    num: "5",
    title: "Tillegg",
    body: "Add-ons og ordreløftere i samme kasse for å øke snittordren. Petit four, slices, premiumkake.",
  },
  {
    num: "6",
    title: "Henting",
    body: "QR-kode for lynrask, sømløs utlevering på pickup-nodet. 3 minutter per kunde.",
  },
];

const tiers = [
  {
    label: "Nivå 1",
    title: "Minimumsordre 396 kr",
    body: "Filtrerer bort ulønnsomme småordre. 1 × 4-pakk signaturmakron starter handlekurven.",
  },
  {
    label: "Nivå 2",
    title: "Ordre over 1 000 kr",
    body: "Utløser 10 % Nobel-kreditt til neste kjøp.",
    accent: "10%",
  },
  {
    label: "Nivå 3",
    title: "Ordre over 1 500 kr",
    body: "Utløser 15 % Nobel-kreditt til neste kjøp.",
    accent: "15%",
  },
  {
    label: "Nivå 4",
    title: "Ordre over 2 000 kr",
    body: "Utløser 20 % Nobel-kreditt til neste kjøp.",
    accent: "20%",
  },
];
---

<BaseLayout
  title="Konseptet"
  description="Slik fungerer Nobel Drop: drops, FOMO, 100 % forhåndsbetalt, faste pickup-vinduer, og Nobel-kreditt-stigen."
>
  <!-- HERO -->
  <section class="relative overflow-hidden pt-24 pb-24 sm:pt-36 sm:pb-32">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(200,162,76,0.08)_0%,transparent_55%)]"
      aria-hidden="true"
    >
    </div>
    <div class="container-edge relative">
      <div class="mx-auto max-w-4xl text-center">
        <SectionLabel label="Slik fungerer Nobel Drop" align="center" />
        <h1
          class="mt-8 font-display text-5xl leading-[1.02] text-bone-100 sm:text-7xl lg:text-[104px]"
          data-fade
        >
          20 sekunder<br /><span class="italic text-shimmer">fra impuls til låst ordre</span>.
        </h1>
        <p class="mx-auto mt-10 max-w-2xl font-sans text-lg leading-relaxed text-bone-300" data-fade>
          Hver overgang er bygget for null friksjon. Push-varsel, valg, betaling,
          tidsvindu, tillegg, henting — seks steg som flyter sammen.
        </p>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- 6 STEG TIMELINE -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl" data-fade>
        <SectionLabel number="01" label="Kundeflyten" />
        <h2 class="mt-6 font-display text-4xl leading-[1.05] text-bone-100 sm:text-5xl">
          Seks steg, sømløs flyt.
        </h2>
      </div>

      <div class="mt-20 grid gap-px bg-gold-400/15 sm:grid-cols-2 lg:grid-cols-3">
        {
          flowSteps.map((s) => (
            <div class="bg-ink-900 p-10 transition hover:bg-ink-850" data-fade>
              <div class="flex items-baseline gap-4">
                <span class="font-display text-5xl text-gold-200">{s.num}</span>
                <span class="font-sans text-[11px] uppercase tracking-ultra-wide text-bone-500">
                  Steg {s.num}
                </span>
              </div>
              <h3 class="mt-6 font-display text-2xl text-bone-100">{s.title}</h3>
              <p class="mt-4 font-sans text-sm leading-relaxed text-bone-400">{s.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- 100% FORHÅNDSBETALT -->
  <section class="relative overflow-hidden py-32 sm:py-44">
    <div class="container-edge relative">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center lg:gap-24">
        <div data-fade>
          <SectionLabel number="02" label="Forhåndsbetaling" />
          <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
            100 % betalt
            <br />
            <span class="italic text-gold-200">før produksjon starter</span>.
          </h2>
          <p class="mt-8 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
            Cashflow før råvaren forlater kjøkkenet. Ingen kontanter ved henting, ingen
            "vi tar det på faktura". Bare en låst, betalt ordre — og en QR-kode på din telefon.
          </p>

          <ul class="mt-10 space-y-5">
            <li class="flex gap-4 border-l border-gold-400/40 pl-6">
              <div>
                <p class="font-display text-lg text-bone-100">Vipps eCom</p>
                <p class="font-sans text-sm text-bone-400">Norges foretrukne mobilbetalingsmetode. 1-klikk til godkjenning.</p>
              </div>
            </li>
            <li class="flex gap-4 border-l border-gold-400/40 pl-6">
              <div>
                <p class="font-display text-lg text-bone-100">Apple Pay</p>
                <p class="font-sans text-sm text-bone-400">Tap-to-pay via Stripe. Bygget for null friksjon i app og web.</p>
              </div>
            </li>
            <li class="flex gap-4 border-l border-gold-400/40 pl-6">
              <div>
                <p class="font-display text-lg text-bone-100">Klarna</p>
                <p class="font-sans text-sm text-bone-400">Faktura eller delbetaling — for større premium-kjøp.</p>
              </div>
            </li>
          </ul>
        </div>

        <div data-fade>
          <HairlineFrame class="aspect-[4/5] bg-gradient-to-br from-ink-850 via-ink-900 to-ink-850">
            <div class="absolute inset-0 flex flex-col items-center justify-center p-10">
              <p class="font-sans text-[10px] uppercase tracking-ultra-wide text-gold-200/80">
                20 sekunder
              </p>
              <p class="mt-3 font-display text-7xl tabular-nums text-bone-100 sm:text-8xl">
                <span class="text-shimmer">00:20</span>
              </p>
              <div class="mt-8 h-px w-24 bg-gold-400/60"></div>
              <p class="mt-8 max-w-xs text-center font-sans text-sm leading-relaxed text-bone-400">
                Reservasjonen utløper på 20 sekunder. Hvis du ikke fullfører betalingen,
                frigjøres plassen til neste kunde.
              </p>
            </div>
          </HairlineFrame>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- PICKUP MEKANIKK -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel number="03" label="Pickup-mekanikken" align="center" />
        <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
          Matematikken bak<br /><span class="italic text-gold-200">kø-fri logistikk</span>.
        </h2>
      </div>

      <div class="mx-auto mt-20 max-w-5xl">
        <div class="grid gap-px bg-gold-400/15 md:grid-cols-3" data-fade>
          <div class="bg-ink-900 p-10 text-center">
            <p class="font-display text-7xl text-gold-200 tabular-nums">90</p>
            <p class="mt-3 font-sans text-xs uppercase tracking-ultra-wide text-bone-400">
              Minutters opphold
            </p>
            <p class="mt-3 font-sans text-sm leading-relaxed text-bone-500">
              Fast vindu per pickup-node. Ingen "fra og med", bare presisjon.
            </p>
          </div>
          <div class="bg-ink-900 p-10 text-center">
            <p class="font-display text-7xl text-gold-200 tabular-nums">30</p>
            <p class="mt-3 font-sans text-xs uppercase tracking-ultra-wide text-bone-400">
              Minutters slots
            </p>
            <p class="mt-3 font-sans text-sm leading-relaxed text-bone-500">
              Vinduet deles i tre slots. Kunden velger ett — kapasitet håndheves atomisk.
            </p>
          </div>
          <div class="bg-ink-900 p-10 text-center">
            <p class="font-display text-7xl text-gold-200 tabular-nums">10</p>
            <p class="mt-3 font-sans text-xs uppercase tracking-ultra-wide text-bone-400">
              Kunder per slot
            </p>
            <p class="mt-3 font-sans text-sm leading-relaxed text-bone-500">
              Maks 10 kunder per 30-minutters slot — det betyr 3 minutter per kunde i kø.
            </p>
          </div>
        </div>

        <div class="mt-10 border border-gold-400/40 bg-ink-850 p-8 text-center" data-fade>
          <p class="font-display text-2xl italic text-gold-200">
            Null kaos. Kun premium overlevering.
          </p>
          <p class="mt-3 font-sans text-sm text-bone-400">
            Appens kapasitetsstyring forhindrer kødannelse automatisk.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- VOLUMSTYRT -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center lg:gap-24">
        <div data-fade>
          <SectionLabel number="04" label="Kickstarter-logistikk" />
          <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
            Forbrukeren <br /><span class="italic text-gold-200">styrer ruten</span>.
          </h2>
          <p class="mt-8 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
            Vi leverer kun når et stopp har nådd sitt minimumsvolum innen cutoff. Hvis
            ikke — refunderes alle ordrer på den noden, eller kunden tilbys flytting til
            en annen node. Null tomkjøring. Risikofri ekspansjon.
          </p>
        </div>

        <div class="space-y-4" data-fade>
          <div class="border border-moss/40 bg-moss/5 p-6">
            <div class="flex items-center justify-between">
              <p class="font-display text-xl text-bone-100">Nabolag A</p>
              <span class="font-sans text-xs uppercase tracking-ultra-wide text-moss">
                Unlocked
              </span>
            </div>
            <div class="mt-4 h-1 w-full overflow-hidden bg-ink-700">
              <div class="h-full w-full bg-moss"></div>
            </div>
            <p class="mt-2 font-sans text-xs text-bone-500">100 % volum nådd · Rute aktivert</p>
          </div>

          <div class="border border-ember/40 bg-ember/5 p-6">
            <div class="flex items-center justify-between">
              <p class="font-display text-xl text-bone-100">Nabolag B</p>
              <span class="font-sans text-xs uppercase tracking-ultra-wide text-ember">
                Skipped · Refund
              </span>
            </div>
            <div class="mt-4 h-1 w-full overflow-hidden bg-ink-700">
              <div class="h-full w-[40%] bg-ember"></div>
            </div>
            <p class="mt-2 font-sans text-xs text-bone-500">40 % av min-volum · Automatisk refusjon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- NOBEL-KREDITT -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel number="05" label="Handlekurv-motoren" align="center" />
        <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
          Aldri rabatt.
          <br />
          <span class="italic text-gold-200">Alltid Nobel-kreditt</span>.
        </h2>
        <p class="mt-8 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
          Rabatt gis aldri som billig prisavslag i kassen. Krediten skaper gjenkjøp og
          massiv AOV uten å svekke premiumfølelsen.
        </p>
      </div>

      <div class="mx-auto mt-20 max-w-3xl space-y-3" data-fade>
        {
          tiers.map((t, i) => (
            <div
              class="flex items-center gap-6 border border-gold-400/30 bg-ink-850 p-6 transition hover:border-gold-400/60"
              style={`margin-left: ${i * 0}px`}
            >
              <div class="flex h-16 w-16 shrink-0 items-center justify-center border border-gold-400/40 bg-ink-900 font-display text-xl text-gold-200">
                {i + 1}
              </div>
              <div class="flex-1">
                <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-gold-200/80">
                  {t.label}
                </p>
                <p class="mt-1 font-display text-xl text-bone-100">{t.title}</p>
                <p class="mt-1 font-sans text-sm text-bone-400">{t.body}</p>
              </div>
              {t.accent && (
                <div class="hidden font-display text-5xl text-gold-200 sm:block">
                  {t.accent}
                </div>
              )}
            </div>
          ))
        }
      </div>

      <div class="mx-auto mt-12 max-w-3xl border-l-2 border-gold-400 bg-ink-850/60 p-8" data-fade>
        <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-gold-200/80">
          Key Rule
        </p>
        <p class="mt-3 font-display text-lg leading-relaxed text-bone-100 sm:text-xl">
          Krediten utløper etter 90 dager. Det skaper urgency for gjenkjøp, samtidig som
          kunden alltid føler at <span class="italic text-gold-200">Nobel gir tilbake</span>.
        </p>
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Klar for første drop?"
    title="Last ned, registrer deg, og vær klar fredag kl. 10:00."
    body="Push-varselet er gratis. Det vi sender, er begjær. Det vi krever, er at du klikker når klokka starter."
    primaryLabel="Åpne app.nobeldrop.no"
    secondaryHref="/produkter"
    secondaryLabel="Se produktene"
  />
</BaseLayout>
