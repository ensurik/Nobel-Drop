---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import HairlineFrame from "~/components/HairlineFrame.astro";
import CTABand from "~/components/CTABand.astro";

const milestones = [
  {
    year: "1986",
    title: "Et lite konditori i Nobelsgate 23",
    body: "To gründere åpner et lite konditori midt i Oslo. De jobber dag og natt — bokstavelig — for å bygge et sted der hver kake som forlater disken har vært verdt å bli plukket ut. Adressen ga navnet, og navnet ble sittende.",
  },
  {
    year: "1990-tallet",
    title: "Catering blir naturlig forlengelse",
    body: "Konditoriet vokser. Bryllup, dåp, konfirmasjon, bursdager — folk spør oftere om de kan få hele bordet, ikke bare kakene. Vi sier ja, og catering blir den andre halvdelen av Nobel.",
  },
  {
    year: "2000-tallet",
    title: "Bærum og Skedsmokorset",
    body: "Veksten gjør at vi etablerer et nytt kjøkken på Skedsmokorset i tillegg til Bærum. Samme oppskrifter, samme standarder — bare større ovner og flere hender. Hele Østlandet blir nedslagsfeltet vårt.",
  },
  {
    year: "2010-tallet",
    title: "Miljøfyrtårn og elektrisk kjøring",
    body: "Vi sertifiserer oss som miljøfyrtårn lenge før det blir et markedsføringsord. Hele leveringsflåten settes om til elektrisk. Lokale, økologiske råvarer der de finnes — fordi vi skal være her i 39 år til.",
  },
  {
    year: "I dag",
    title: "Rundt 40 hender på kjøkkenet",
    body: "Bakere, konditorer, kjøkkensjefer, sjåfører. Vi serverer privatpersoner og bedrifter over hele Østlandet — bryllup om sommeren, julebord om vinteren, og noe nytt på fredagene.",
  },
  {
    year: "Nå",
    title: "Nobel Drop åpner dørene",
    body: "Tradisjonell catering har alltid krevd at du ringer inn en bestilling i forveien. Med Nobel Drop åpner vi en ny dør — du kan bestille for fredagskvelden mens du sitter i kø på vei til jobb mandag morgen. Samme kjøkken, samme håndverk, ny måte å nå deg på.",
  },
];

const principles = [
  {
    label: "Kvalitet",
    title: "Bakt fra bunnen, hver gang",
    body: "Smør, ekte mandelmel, friske bær, sjokolade fra produsenter vi kjenner. Vi tar snarveiene aldri i kjøkkenet — det er det vi har 39 år for å vite.",
  },
  {
    label: "Variasjon",
    title: "Sesongstyrt sortiment",
    body: "Drops varierer gjennom året. Vinteren har mer sjokolade og krydder; sommeren har bær og lette kremer. Vi følger råvarene, ikke kalenderen.",
  },
  {
    label: "Bærekraft",
    title: "Mindre kjøtt, kortere transport",
    body: "Hele leveringsflåten er elektrisk. Vi prioriterer lokalt og økologisk der det er mulig, og bruker mindre kjøtt år for år. Drop-modellen betyr i tillegg at vi nesten ikke kaster noe — vi baker mot låste bestillinger.",
  },
];
---

<BaseLayout
  title="Om Nobel"
  description="Nobel Catering & Conditori ble etablert i Nobelsgate 23 i 1986 av to gründere som 'jobbet dag og natt'. 39 år senere bakes hver Nobel Drop fortsatt fra bunnen, fra de samme kjøkkenene."
>
  <!-- HERO -->
  <section class="relative overflow-hidden pt-24 pb-32 sm:pt-36 sm:pb-44">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(200,162,76,0.08)_0%,transparent_55%)]"
      aria-hidden="true"
    >
    </div>
    <div class="container-edge relative">
      <div class="mx-auto max-w-4xl">
        <SectionLabel label="Om Nobel · Etablert 1986" />
        <h1
          class="mt-8 font-display text-5xl leading-[1.02] text-bone-100 sm:text-7xl lg:text-[104px]"
          data-fade
        >
          Bakt for hånd
          <br />
          <span class="italic text-shimmer">i 39 år.</span>
        </h1>
        <p class="mt-12 max-w-2xl font-sans text-lg leading-relaxed text-bone-300" data-fade>
          Nobel Drop er ikke et nytt selskap. Det er en ny måte å dele kakene fra et
          konditori som har stått i Oslo og Bærum siden 1986.
        </p>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- INTRO + PORTRAIT -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center lg:gap-24">
        <div class="lg:col-span-7" data-fade>
          <SectionLabel label="Hvorfor det heter Nobel" />
          <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-5xl">
            Et navn som
            <br />
            <span class="italic text-gold-200">begynte med en adresse</span>.
          </h2>
          <div class="mt-10 space-y-6 font-sans text-base leading-relaxed text-bone-300 sm:text-lg">
            <p>
              I 1986 åpnet to gründere et lite konditori i Nobelsgate 23 i Oslo. De
              hadde verken stort budsjett eller en plan om å bli store — bare en idé om
              at det fantes plass for noen som baket kakene fra bunnen, hver morgen.
            </p>
            <p>
              Navnet kom av adressen, og det har stått siden. Selv etter at vi flyttet
              til Bærum og senere åpnet et andre kjøkken på Skedsmokorset, har Nobel
              vært det samme: en kake skal smake av smør, mandel, sjokolade — ikke av
              snarveier.
            </p>
            <p>
              I dag er det rundt 40 ansatte som baker, koker og pakker fra de to
              kjøkkenene. Vi leverer mat og kaker til private selskaper, bryllup, dåp og
              bedrifter over hele Østlandet. Nobel Drop er bare den nyeste døren ut til deg.
            </p>
          </div>
        </div>

        <div class="lg:col-span-5" data-fade>
          <HairlineFrame class="aspect-[4/5] bg-gradient-to-br from-ink-850 via-ink-900 to-ink-800">
            <div class="absolute inset-0 flex flex-col items-center justify-center p-10 text-center">
              <p class="font-sans text-[10px] uppercase tracking-ultra-wide text-gold-200/80">
                Etablert
              </p>
              <p class="mt-6 font-display text-[96px] leading-none text-gold-200 sm:text-[128px]">
                1986
              </p>
              <div class="mt-8 h-px w-16 bg-gold-400/60"></div>
              <p class="mt-8 max-w-xs font-display text-lg italic text-bone-200">
                "Vi jobbet dag og natt."
              </p>
              <p class="mt-3 font-sans text-xs uppercase tracking-ultra-wide text-bone-500">
                Grunnleggerne, om de første årene
              </p>
            </div>
          </HairlineFrame>
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- TIDSLINJE -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl" data-fade>
        <SectionLabel label="Tidslinje" />
        <h2 class="mt-6 font-display text-4xl leading-[1.05] text-bone-100 sm:text-5xl">
          Fra konditoridisk til pickup-stopp.
        </h2>
      </div>

      <div class="relative mt-20">
        <div class="absolute left-6 top-0 bottom-0 hidden w-px bg-gradient-to-b from-gold-400/40 via-gold-400/20 to-transparent sm:block"></div>

        <div class="space-y-16">
          {
            milestones.map((m) => (
              <div class="relative flex gap-8 pl-0 sm:gap-12 sm:pl-16" data-fade>
                <div class="absolute left-0 top-2 hidden h-3 w-3 -translate-x-[6px] rounded-full border border-gold-400 bg-ink-900 sm:block" />
                <div class="w-32 shrink-0">
                  <p class="font-display text-2xl text-gold-200 sm:text-3xl">{m.year}</p>
                </div>
                <div class="flex-1 border-l border-ink-600 pl-6">
                  <h3 class="font-display text-2xl text-bone-100 sm:text-3xl">{m.title}</h3>
                  <p class="mt-3 font-sans text-base leading-relaxed text-bone-300">{m.body}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- PRINSIPPER -->
  <section class="relative py-32 sm:py-44">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Bærebjelker" align="center" />
        <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
          Tre prinsipper.
          <br /><span class="italic text-gold-200">Bakt inn i alt vi gjør.</span>
        </h2>
      </div>

      <div class="mt-20 grid gap-px bg-gold-400/15 md:grid-cols-3" data-fade>
        {
          principles.map((p, i) => (
            <div class="bg-ink-900 p-10">
              <p class="font-display text-5xl text-gold-200">
                {String(i + 1).padStart(2, "0")}
              </p>
              <p class="mt-6 font-sans text-[11px] uppercase tracking-ultra-wide text-gold-200/80">
                {p.label}
              </p>
              <h3 class="mt-3 font-display text-2xl text-bone-100">{p.title}</h3>
              <p class="mt-4 font-sans text-sm leading-relaxed text-bone-400">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- BROEN -->
  <section class="relative overflow-hidden py-32 sm:py-44">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(200,162,76,0.10)_0%,transparent_50%)]"
      aria-hidden="true"
    >
    </div>
    <div class="container-edge relative">
      <div class="mx-auto max-w-3xl text-center" data-fade>
        <SectionLabel label="Drop er Nobel" align="center" />
        <h2 class="mt-8 font-display text-4xl leading-[1.05] text-bone-100 sm:text-6xl">
          Samme hender.<br /><span class="italic text-gold-200">Ny måte å dele.</span>
        </h2>
        <p class="mt-10 font-sans text-lg leading-relaxed text-bone-300">
          Nobel Drop er bakt på de samme to kjøkkenene som leverer bryllupskaken til
          tantes andre forsøk. Forskjellen er at du ikke trenger å ringe en uke i
          forveien. Last ned appen, slå på varsler, og du er klar til neste fredag.
        </p>
      </div>

      <div class="mx-auto mt-16 max-w-3xl border border-gold-400/40 bg-ink-850 p-10" data-fade>
        <p class="font-display text-2xl leading-relaxed text-bone-100 sm:text-3xl">
          "Vi har bakt for byen i 39 år. Nobel Drop er bare første gang vi sender det
          <span class="italic text-gold-200">direkte til deg</span>."
        </p>
      </div>

      <div class="mt-12 flex justify-center">
        <GoldButton href="https://nobelcatering.no" external variant="ghost">
          Bestill catering på nobelcatering.no
        </GoldButton>
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Klar for fredag?"
    title="39 år med håndverk. Ett trykk unna."
    body="Last ned, slå på varsler, og bli en del av neste fredags drop."
    primaryLabel="Last ned appen"
    secondaryHref="/slik-fungerer-det"
    secondaryLabel="Slik fungerer det"
  />
</BaseLayout>
