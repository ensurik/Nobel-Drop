---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
---

<BaseLayout title="404 — Ikke funnet" description="Siden du leter etter finnes ikke.">
  <section class="relative flex min-h-[80vh] items-center py-24">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl text-center">
        <SectionLabel label="Feil 404" align="center" />
        <h1 class="mt-8 font-display text-[88px] font-medium leading-none text-brass-700 sm:text-[160px]" data-fade>
          404
        </h1>
        <p class="mt-8 font-display text-[28px] font-medium leading-tight text-espresso-900 sm:text-[44px]" data-fade>
          Dette dropet finnes ikke.
        </p>
        <p class="mx-auto mt-6 max-w-xl font-sans text-[16px] leading-relaxed text-espresso-700 sm:text-[17px]" data-fade>
          Lenken er enten utløpt, eller du skrev feil. Sjansen for at det er det
          første er størst — drops varer ikke lenge.
        </p>
        <div class="mt-12 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4" data-fade>
          <GoldButton href="/" variant="primary" size="lg">
            Tilbake til forsiden
          </GoldButton>
          <GoldButton href="https://shop.nobeldrop.no" variant="ghost" size="lg" arrow={false}>
            Bestill nå
          </GoldButton>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
