---
import BaseLayout from "~/layouts/BaseLayout.astro";
import GoldButton from "~/components/GoldButton.astro";
import SectionLabel from "~/components/SectionLabel.astro";
import Photo from "~/components/Photo.astro";

const contactBlocks = [
  {
    label: "Bestilling & henting",
    title: "Spørsmål om dropet, henting, eller refusjon",
    email: "hello@nobeldrop.no",
    response: "Vi svarer innen 24 timer på hverdager",
  },
  {
    label: "Presse & samarbeid",
    title: "Saker, intervjuer, samarbeid om hentesteder",
    email: "presse@nobeldrop.no",
    response: "Vi svarer raskest på saker med deadline",
  },
  {
    label: "Tradisjonell bestilling",
    title: "Catering, bryllup, dåp, bedriftsarrangement",
    email: "post@nobelcatering.no",
    response: "Eller besøk nobelcatering.no direkte",
  },
];
---

<BaseLayout
  title="Kontakt"
  description="Kom i kontakt med oss bak Nobel Drop. Bestilling, henting, presse, eller tradisjonell catering fra Nobel Catering & Conditori."
>
  <!-- HERO -->
  <section class="relative pt-12 pb-20 sm:pt-20 sm:pb-28">
    <div class="container-edge">
      <div class="mx-auto max-w-3xl">
        <SectionLabel label="Kontakt" />
        <h1
          class="mt-8 font-display text-[52px] font-medium leading-[0.98] tracking-tight text-espresso-900 sm:text-7xl lg:text-[80px]"
          data-fade
        >
          Vi svarer alle,
          <br />
          <span class="display-italic text-brass-700">alltid</span>.
        </h1>
        <p class="mt-10 max-w-xl font-sans text-[17px] leading-relaxed text-espresso-700 sm:text-[18px]" data-fade>
          Spør oss om alt. Vi liker spørsmål — det er sånn vi har bygget Nobel
          i 39 år.
        </p>
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- KONTAKT-BLOKKER -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="grid gap-px bg-espresso-900/10 lg:grid-cols-3" data-fade>
        {
          contactBlocks.map((b) => (
            <div class="group flex flex-col bg-cream-50 p-10 transition hover:bg-cream-100">
              <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-brass-700">
                {b.label}
              </p>
              <h3 class="mt-4 flex-1 font-display text-[22px] font-medium leading-tight text-espresso-900 sm:text-[24px]">
                {b.title}
              </h3>
              <a
                href={`mailto:${b.email}`}
                class="mt-8 font-display text-[18px] font-medium text-brass-700 transition hover:text-brass-800 sm:text-[20px]"
              >
                {b.email}
              </a>
              <p class="mt-3 font-sans text-[11px] uppercase tracking-ultra-wide text-espresso-500">
                {b.response}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <div class="hairline mx-auto max-w-5xl"></div>

  <!-- ADRESSE -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-20">
        <div class="lg:col-span-5" data-fade>
          <SectionLabel label="Kjøkkenet" />
          <h2 class="mt-8 font-display text-[40px] font-medium leading-[1.05] text-espresso-900 sm:text-[52px]">
            Nobel Catering
            <br />
            <span class="display-italic text-brass-700">& Conditori</span>
          </h2>
          <p class="mt-6 font-sans text-[16px] leading-relaxed text-espresso-700">
            Vi lager fra Bærum, med et ekstra kjøkken på Skedsmokorset.
            Hovedkjøkkenet er ikke åpent for besøk uten avtale, men send oss en
            mail så svarer vi på alt innen et døgn.
          </p>

          <address class="mt-10 not-italic">
            <p class="font-display text-[24px] font-medium text-espresso-900">
              Eiksveien 110
            </p>
            <p class="mt-1 font-sans text-[16px] text-espresso-700">1361 Østerås</p>
            <p class="mt-1 font-sans text-[16px] text-espresso-700">Bærum, Norge</p>
          </address>

          <div class="mt-10 space-y-2 font-sans text-[14px] text-espresso-600">
            <p><span class="text-espresso-500">Org.nr:</span> 931 878 409</p>
            <p><span class="text-espresso-500">Etablert:</span> 1986</p>
            <p>
              <span class="text-espresso-500">Søsterside:</span>{" "}
              <a href="https://nobelcatering.no" class="link-brass">
                nobelcatering.no
              </a>
            </p>
          </div>
        </div>

        <div class="lg:col-span-7" data-fade>
          <Photo
            src="/assets/about/storefront.jpg"
            alt="Nobel Catering & Conditori, eksteriør i Bærum"
            aspect="aspect-[5/4]"
            fallbackLabel="Bilde · Eksteriør"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-24 sm:py-32">
    <div class="container-edge">
      <div
        class="mx-auto flex max-w-4xl flex-col items-center gap-8 rounded-lg border border-espresso-900/10 bg-cream-50 p-12 text-center photo-frame"
        data-fade
      >
        <p class="font-sans text-[11px] uppercase tracking-ultra-wide text-brass-700">
          Vil du heller bare bestille?
        </p>
        <h2 class="font-display text-[28px] font-medium leading-tight text-espresso-900 sm:text-[44px]">
          Åpne appen og se neste drop.
        </h2>
        <GoldButton href="https://shop.nobeldrop.no" variant="primary" size="lg">
          Bestill nå
        </GoldButton>
      </div>
    </div>
  </section>
</BaseLayout>
